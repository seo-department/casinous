<script>
    function initCasedgeCompare() {
        const checkboxes = document.querySelectorAll("[data-casedge-compare]")
        if (!checkboxes.length) return
        if (checkboxes[0].dataset.compareBound === "true") return

        const modal = document.querySelector("[data-casedge-compare-modal]")
        const content = document.querySelector("[data-casedge-compare-content]")
        const countText = document.querySelector("[data-casedge-compare-count]")
        const closeButtons = document.querySelectorAll(
            "[data-casedge-compare-close]",
        )

        if (!modal || !content) return

        let selected = []

        function openModal() {
            modal.hidden = false
        }

        function closeModal() {
            modal.hidden = true
        }

        function updateCountText() {
            if (!countText) return
            if (selected.length === 0) {
                countText.textContent = "Compare selected casinos side by side."
            } else if (selected.length === 1) {
                countText.textContent = "Select one more casino to compare."
            } else {
                countText.textContent = `${selected.length} casinos selected for comparison.`
            }
        }

        // Determines which of the two selected values is "better" for a stat,
        // and returns a highlight class for each column accordingly
        function statRow(label, key, higherIsBetter = true) {
            const values = selected.map(e => e[key])
            const numeric = values.map(v => {
                const n = parseFloat(String(v).replace(/[^0-9.]/g, ""))
                return isNaN(n) ? null : n
            })

            let betterIndex = -1
            if (
                numeric[0] !== null &&
                numeric[1] !== null &&
                numeric[0] !== numeric[1]
            ) {
                betterIndex = higherIsBetter
                    ? numeric[0] > numeric[1]
                        ? 0
                        : 1
                    : numeric[0] < numeric[1]
                        ? 0
                        : 1
            }

            return `
                <div class="casedge-compare-row-label">${label}</div>
                <div class="casedge-compare-row">
                    ${selected
                        .map(
                            (e, i) =>
                                `<div class="${i === betterIndex ? "is-better" : ""}"><strong>${e[key] ?? "N/A"}</strong></div>`,
                        )
                        .join("")}
                </div>
            `
        }

        function renderComparison() {
            if (selected.length < 2) {
                content.innerHTML = ""
                return
            }

            const columnsHtml = `
                <div class="casedge-compare-columns">
                    ${selected
                        .map(
                            entry => `
                        <div class="casedge-compare-col">
                            <img src="${entry.logo}" alt="${entry.name} logo" loading="lazy">
                            <strong>${entry.name}</strong>
                            <div>${entry.score}/10</div>
                            <a href="${entry.reviewUrl}" class="casedge-compare-col-review">Read review</a>
                        </div>
                    `,
                        )
                        .join("")}
                </div>
            `

            const bonusRow = `
                <div class="casedge-compare-row">
                    ${selected.map(e => `<div>${e.bonus}</div>`).join("")}
                </div>
            `

            const statsHtml =
                statRow("Wagering Req", "wagering", false) +
                statRow("Min Deposit", "minDeposit", false) +
                statRow("Free Spins", "freeSpins", true)

            const licenceRow = `
                <div class="casedge-compare-row">
                    ${selected.map(e => `<div>${e.licence}</div>`).join("")}
                </div>
            `

            const codeRow = statRow("Bonus Code", "bonusCode")

            const ctaRow = `
                <div class="casedge-compare-row">
                    ${selected
                        .map(
                            e => `
                        <div>
                            <a href="/" class="casedge-cta-button" target="_blank" rel="noopener noreferrer nofollow sponsored" data-operator-id="${e.id}" data-operator="${e.slug}" data-toplist-id="${e.toplistId}" data-page-id="${e.pageId}">
                                Claim Bonus
                            </a>
                        </div>
                    `,
                        )
                        .join("")}
                </div>
            `

            content.innerHTML =
                columnsHtml + bonusRow + statsHtml + licenceRow + codeRow + ctaRow
        }

        checkboxes.forEach(checkbox => {
            checkbox.addEventListener("change", () => {
                const raw = checkbox.getAttribute("data-compare-entry")
                let entry
                try {
                    entry = JSON.parse(raw)
                } catch (err) {
                    console.error("Invalid compare entry JSON:", err)
                    return
                }

                const label = checkbox.closest(".casedge-compare-toggle")
                if (label) label.classList.toggle("is-checked", checkbox.checked)

                if (checkbox.checked) {
                    if (selected.length >= 2) {
                        const removedId = selected[0].id
                        selected.shift()

                        const oldCheckbox = document.querySelector(
                            `[data-casedge-compare][data-compare-entry*="${removedId}"]`,
                        )
                        if (oldCheckbox) {
                            oldCheckbox.checked = false
                            const oldLabel = oldCheckbox.closest(
                                ".casedge-compare-toggle",
                            )
                            if (oldLabel) oldLabel.classList.remove("is-checked")
                        }
                    }
                    selected.push(entry)
                } else {
                    selected = selected.filter(e => e.id !== entry.id)
                }

                updateCountText()
                renderComparison()

                if (selected.length === 2) {
                    openModal()
                }
            })
        })

        closeButtons.forEach(btn => {
            btn.addEventListener("click", closeModal)
        })

        checkboxes.forEach(cb => (cb.dataset.compareBound = "true"))
    }

    document.addEventListener("DOMContentLoaded", initCasedgeCompare)
    document.addEventListener("astro:page-load", initCasedgeCompare)
</script>


<script>
    document.addEventListener("DOMContentLoaded", () => {
        const faqToggles = document.querySelectorAll(".cus-faq-toggle")

        faqToggles.forEach(toggle => {
            toggle.addEventListener("click", e => {
                const btn = e.currentTarget // Removed 'as HTMLElement' for standard JS parsing
                const item = btn.closest(".cus-faq-item")
                if (!item) return

                const answer = item.querySelector(".cus-faq-answer")
                if (!answer) return

                const isOpen = item.classList.contains("active")

                // Optional: Close all other open accordions
                document
                    .querySelectorAll(".cus-faq-item.active")
                    .forEach(activeItem => {
                        if (activeItem !== item) {
                            activeItem.classList.remove("active")

                            const activeToggle =
                                activeItem.querySelector(".cus-faq-toggle")
                            if (activeToggle) {
                                activeToggle.setAttribute(
                                    "aria-expanded",
                                    "false",
                                )
                            }

                            const activeAnswer =
                                activeItem.querySelector(".cus-faq-answer")
                            if (activeAnswer) {
                                activeAnswer.style.maxHeight = ""
                            }
                        }
                    })

                // Toggle the current clicked accordion
                if (isOpen) {
                    // Close it (No reflow issue here)
                    item.classList.remove("active")
                    btn.setAttribute("aria-expanded", "false")
                    answer.style.maxHeight = ""
                } else {
                    // Open it (🚨 THE FIX: Separate writes and reads into animation frames)
                    requestAnimationFrame(() => {
                        // 1. Write: Add the class
                        item.classList.add("active")
                        btn.setAttribute("aria-expanded", "true")

                        // 2. Read & Write: Wait for the next natural browser paint to check the height
                        requestAnimationFrame(() => {
                            answer.style.maxHeight = answer.scrollHeight + "px"
                        })
                    })
                }
            })
        })
    })
</script>

<script is:inline>
    document.addEventListener("click", function (e) {
        // Check if what we clicked was an accordion button (or an icon inside it)
        const button = e.target.closest(".twaccbutton")
        if (!button) return

        // Find the target content box
        const targetId = button.getAttribute("data-bs-target")
        const targetContent = document.querySelector(targetId)

        if (targetContent) {
            // 1. Strip the WordPress/Tailwind hidden class just in case
            targetContent.classList.remove("tw-hidden")

            // 2. Toggle our own custom 'force-open' class
            const isNowOpen = targetContent.classList.toggle("cus-force-open")

            // 3. Update the + and - icon
            if (isNowOpen) {
                button.classList.remove("collapsed")
            } else {
                button.classList.add("collapsed")
            }
        }
    })
</script>

<script is:inline>
    document.addEventListener("click", function (e) {
        // Did we click an FAQ button?
        const faqBtn = e.target.closest(".twfaqbutton")
        if (!faqBtn) return

        // Prevent page jump
        e.preventDefault()

        // Get the target content div via the data attribute
        const targetId = faqBtn.getAttribute("data-bs-target")
        if (!targetId) return

        const targetContent = document.querySelector(targetId)

        if (targetContent) {
            // Remove the hardcoded Tailwind hidden class
            targetContent.classList.remove("tw-hidden")

            // Toggle our custom open class to show the text
            const isOpen = targetContent.classList.toggle("cus-faq-open")

            // Update the button class to trigger the arrow flip animation
            if (isOpen) {
                faqBtn.classList.remove("collapsed")
                faqBtn.setAttribute("aria-expanded", "true")
            } else {
                faqBtn.classList.add("collapsed")
                faqBtn.setAttribute("aria-expanded", "false")
            }
        }
    })
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Grab all the accordion buttons
        const accordionButtons = document.querySelectorAll(".twaccbutton")

        accordionButtons.forEach(button => {
            button.addEventListener("click", function () {
                // 1. Safely get the target attribute
                const targetId = button.getAttribute("data-bs-target")

                // 2. Stop if the attribute doesn't exist or is empty
                if (!targetId) {
                    console.warn(
                        "A button is missing the 'data-bs-target' attribute.",
                        button,
                    )
                    return
                }

                try {
                    // 3. Try to find the matching content div
                    const contentDiv = document.querySelector(targetId)

                    // 4. If found, toggle the classes
                    if (contentDiv) {
                        button.classList.toggle("collapsed")
                        contentDiv.classList.toggle("tw-hidden")
                    } else {
                        console.warn(
                            "Could not find the content div for this ID:",
                            targetId,
                        )
                    }
                } catch (error) {
                    // Catch any syntax errors from invalid IDs (e.g., missing '#' or spaces in the ID)
                    console.error(
                        "Invalid selector format for targetId:",
                        targetId,
                        error,
                    )
                }
            })
        })
    })
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const moreInfoBtns = document.querySelectorAll(".cus-more-info-btn")

        moreInfoBtns.forEach(btn => {
            // Changed to an arrow function
            btn.addEventListener("click", () => {
                // Use 'btn' instead of 'this'
                const card = btn.closest(".cus-casino-card")

                // Added a safety check to ensure the card exists
                if (!card) return

                const expandedBox = card.querySelector(".cus-expanded-info")
                if (!expandedBox) return

                const isHidden =
                    expandedBox.style.display === "none" ||
                    expandedBox.style.display === ""
                expandedBox.style.display = isHidden ? "block" : "none"

                if (isHidden) {
                    btn.innerHTML =
                        'Less Information <i class="fa-solid fa-chevron-up"></i>'
                } else {
                    btn.innerHTML =
                        'More Information <i class="fa-solid fa-chevron-down"></i>'
                }
            })
        })
    })
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const voteContainers = document.querySelectorAll(".cus-votes")

        voteContainers.forEach(async container => {
            const casinoId = container.getAttribute("data-casino-id")
            const upBtn = container.querySelector(".cus-vote-up")
            const downBtn = container.querySelector(".cus-vote-down")

            if (!casinoId) return

            // ==========================================
            // 1. FETCH THE REAL VOTES ON PAGE LOAD
            // ==========================================
            try {
                const response = await fetch(`/api/get-votes?id=${casinoId}`)
                const data = await response.json()

                // Update the HTML with the numbers from the database
                if (upBtn)
                    upBtn.querySelector(".vote-count").textContent =
                        data.upVotes
                if (downBtn)
                    downBtn.querySelector(".vote-count").textContent =
                        data.downVotes
            } catch (error) {
                console.error("Failed to load current votes:", error)
            }

            // ==========================================
            // 2. CHECK IF USER ALREADY VOTED (LOCAL)
            // ==========================================
            const previousVote = localStorage.getItem(`voted_on_${casinoId}`)
            if (previousVote === "up" && upBtn) {
                upBtn.classList.add("active-vote")
            } else if (previousVote === "down" && downBtn) {
                downBtn.classList.add("active-vote")
            }

            // ==========================================
            // 3. HANDLE NEW VOTES
            // ==========================================
            const handleVote = async (type, clickedBtn) => {
                // Stop them if they already voted locally
                if (localStorage.getItem(`voted_on_${casinoId}`)) return

                // Optimistic UI: Make the number go up instantly for the user
                const countSpan = clickedBtn.querySelector(".vote-count")
                if (countSpan) {
                    let currentCount = parseInt(countSpan.textContent, 10) || 0
                    countSpan.textContent = currentCount + 1
                }

                // Add active color and lock them out locally
                clickedBtn.classList.add("active-vote")
                localStorage.setItem(`voted_on_${casinoId}`, type)

                // Send the new vote to the Vercel Database
                try {
                    await fetch("/api/vote", {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify({
                            casinoId: casinoId,
                            type: type,
                        }),
                    })
                } catch (error) {
                    console.error("Failed to save vote:", error)
                }
            }

            // Attach click events
            if (upBtn) {
                upBtn.addEventListener("click", () => handleVote("up", upBtn))
            }
            if (downBtn) {
                downBtn.addEventListener("click", () =>
                    handleVote("down", downBtn),
                )
            }
        })
    })
</script>

<script>
    // Wrap the logic in a function so it can be called safely
    function initMobileMenu() {
        const toggleBtn = document.querySelector(".mobile-menu-toggle")
        const nav = document.querySelector(".header-nav")

        // ASTRO FIX: Prevent errors if elements don't exist on the current page
        if (!toggleBtn || !nav) return

        const icon = toggleBtn.querySelector("i")

        // 1. Main Mobile Menu Toggle
        toggleBtn.addEventListener("click", function () {
            nav.classList.toggle("active")

            // ASTRO FIX: Check if icon exists before manipulating
            if (icon) {
                if (nav.classList.contains("active")) {
                    icon.classList.remove("fa-bars")
                    icon.classList.add("fa-xmark")
                } else {
                    icon.classList.remove("fa-xmark")
                    icon.classList.add("fa-bars")
                }
            }
        })

        // 2. Mobile Dropdown Toggle (Accordion effect)
        const dropdownToggles = document.querySelectorAll(
            ".nav-dropdown-toggle",
        )

        dropdownToggles.forEach(btn => {
            // ASTRO FIX: Remove old event listeners to prevent duplicates during View Transitions
            // (Astro runs scripts multiple times if you navigate back and forth)
            const newBtn = btn.cloneNode(true)
            btn.parentNode.replaceChild(newBtn, btn)

            newBtn.addEventListener("click", function (e) {
                if (window.innerWidth <= 991) {
                    e.preventDefault()

                    const parentDropdown = this.parentElement
                    if (!parentDropdown) return

                    parentDropdown.classList.toggle("open")

                    const chevron = this.querySelector(".fa-chevron-down")
                    if (chevron) {
                        if (parentDropdown.classList.contains("open")) {
                            chevron.style.transform = "rotate(180deg)"
                        } else {
                            chevron.style.transform = "rotate(0deg)"
                        }
                    }
                }
            })
        })
    }

    // ASTRO FIX: Support both standard loads and Astro View Transitions
    document.addEventListener("DOMContentLoaded", initMobileMenu)
    document.addEventListener("astro:page-load", initMobileMenu)
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Grab every single tab on the entire page
        const allTabs = document.querySelectorAll(".sidebar-nav-item")

        allTabs.forEach(tab => {
            tab.addEventListener("click", function () {
                // THE FIX: Find the main parent container for THIS specific clicked tab
                const currentSection = this.closest(".container-wrapper")

                // 1. Query only the tabs, contents, and wrapper inside THIS specific section
                const sectionTabs =
                    currentSection.querySelectorAll(".sidebar-nav-item")
                const sectionContents =
                    currentSection.querySelectorAll(".tab-content")
                const sectionWrapper = currentSection.querySelector(
                    ".tab-content-wrapper",
                )

                // 2. Remove active classes ONLY from this section's items
                sectionTabs.forEach(t => t.classList.remove("active"))
                sectionContents.forEach(c => c.classList.remove("active"))

                // 3. Add active class to the clicked tab
                this.classList.add("active")

                // 4. Show the corresponding content
                const targetId = this.getAttribute("data-target")
                document.getElementById(targetId).classList.add("active")

                // 5. THE MOBILE SCROLL FIX (Now targets the correct wrapper!)
                if (window.innerWidth <= 768 && sectionWrapper) {
                    setTimeout(() => {
                        sectionWrapper.scrollIntoView({
                            behavior: "smooth",
                            block: "start",
                        })
                    }, 50)
                }
            })
        })
    })
</script>

