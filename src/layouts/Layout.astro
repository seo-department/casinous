    }
    .breaking-story-card:hover {
        transform: translateX(4px);
    }

    .breaking-story-image {
        width: 220px;
        min-width: 220px;
    }

    .breaking-story-image img {
        width: 100%;
        height: 130px;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    }

    .breaking-story-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* --- 4. Right Sidebar (Discover Blogs) --- */
    .discovery-right-col {
        background: #f8fafc; /* Soft gray box */
        padding: 32px;
        border-radius: 16px;
        border: 1px solid #e2e8f0;
    }

    .blog-post-card {
        display: flex;
        gap: 16px;
        margin-bottom: 24px;
        transition: transform 0.2s ease;
    }

    .blog-post-card:last-child {
        margin-bottom: 0;
    }
    .blog-post-card:hover {
        transform: translateX(4px);
    }

    .blog-post-image {
        width: 120px;
        min-width: 120px;
    }

    .blog-post-image img {
        width: 100%;
        height: 80px;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 2px 6px rgba(0, 0, 0, 0.08);
    }

    .blog-post-content {
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    /* --- 5. Shared Typography --- */
    .card-meta-top {
        display: flex;
        gap: 8px;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        color: #64748b;
        margin-bottom: 6px;
        letter-spacing: 0.5px;
    }

    .card-category {
        color: #2563eb;
    } /* Blue accent for 'News' */

    .card-title-link,
    .blog-title-link {
        text-decoration: none;
        color: #0f172a;
    }

    .card-title-link h3 {
        font-size: 15px;
        font-weight: 500;
        line-height: 1.3;
        margin: 0 0 10px 0;
        transition: color 0.2s ease;
    }

    .blog-title-link h3 {
        font-size: 13px;
        font-weight: 400;
        line-height: 1.4;
        margin: 0 0 8px 0;
        transition: color 0.2s ease;
    }

    .card-title-link:hover h3,
    .blog-title-link:hover h3 {
        color: #2563eb;
    }

    .card-meta-bottom,
    .blog-meta-author {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 12px;
        color: #475569;
        font-weight: 500;
    }

    .card-author-avatar,
    .blog-author-avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        border: 1px solid #cbd5e1;
    }

    .blog-read-more {
        font-size: 12px;
        font-weight: 800;
        color: #2563eb;
        text-decoration: none;
        margin-top: 6px;
        display: inline-block;
        transition: color 0.2s ease;
    }

    .blog-read-more:hover {
        color: #1d4ed8;
    }

    /* --- 6. Mobile Responsiveness --- */
    @media (max-width: 900px) {
        .discovery-columns {
            grid-template-columns: 1fr; /* Stacks columns vertically */
            gap: 40px;
        }

        .breaking-story-card,
        .blog-post-card {
            flex-direction: column; /* Stacks image above text */
            gap: 12px;
        }

        .breaking-story-image,
        .blog-post-image {
            width: 100%;
            min-width: 100%;
        }

        .breaking-story-image img {
            height: 180px;
        }
        .blog-post-image img {
            height: 160px;
        }

        .discovery-right-col {
            padding: 20px;
        }
    }

    /* --- Clickable Header --- */
    .toc-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #f8fafc;
        padding: 16px 20px;
        cursor: pointer;
        transition: background-color 0.2s ease;
        user-select: none; /* Prevents text highlighting if clicked fast */
    }

    .toc-header:hover {
        background-color: #f1f5f9;
    }

    .toc-header strong {
        font-size: 16px;
        color: #1e293b;
        font-weight: 600;
    }

    /* --- The Arrow --- */
    .toc-arrow {
        font-size: 12px;
        color: #64748b;
        transition: transform 0.3s ease; /* Smooth rotation */
    }

    /* --- Hidden Body Area --- */
    .toc-body {
        display: none; /* STRICTLY HIDDEN BY DEFAULT */
        padding: 20px;
        border-top: 1px solid #e2e8f0;
        max-height: 400px; /* Prevents massive TOCs from taking over the screen */
        overflow-y: auto; /* Adds a scrollbar if the list is too long */
    }

    /* --- List & Links Styling --- */
    .toc-body ul {
        list-style: none; /* Removes messy default bullets */
        margin: 0;
        padding: 0;
    }

    .toc-body li {
        margin-bottom: 12px;
        position: relative;
        padding-left: 16px;
    }

    /* Custom modern bullet point */
    .toc-body li::before {
        content: "•";
        color: #3b82f6;
        position: absolute;
        left: 0;
        font-weight: bold;
    }

    .toc-body li:last-child {
        margin-bottom: 0;
    }

    .toc-body a {
        color: #475569;
        text-decoration: none;
        font-size: 14.5px;
        font-weight: 500;
        transition:
            color 0.2s ease,
            transform 0.2s ease;
        display: inline-block;
    }

    /* Subtle nudge to the right on hover */
    .toc-body a:hover {
        color: #2563eb;
        text-decoration: underline;
        transform: translateX(4px);
    }

    /* --- Active/Open States (Triggered by JS) --- */
    .toc-wrapper.is-open .toc-body {
        display: block; /* Unhides the list */
    }

    .toc-wrapper.is-open .toc-arrow {
        transform: rotate(180deg); /* Flips the arrow upside down */
    }

    /* --- Toggle Button --- */
    .cus-toggle {
        display: inline-block;
        margin-left: 8px;
        padding: 6px 18px;
        background-color: #fbbf24;
        color: #1e3a8a !important;
        font-weight: 600;
        font-size: 14px;
        text-decoration: none;
        border-radius: 24px;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
    }

    .cus-toggle:hover {
        background-color: #f59e0b;
        transform: translateY(-2px);
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
    }

    /* --- Table Styling --- */
    .cus-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 16px;
        background: rgba(
            0,
            0,
            0,
            0.15
        ); /* Slightly darker translucent background */
        border-radius: 8px;
        overflow: hidden;
    }

    .cus-table th,
    .cus-table td {
        padding: 16px;
        text-align: left;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .cus-table th {
        background: rgba(0, 0, 0, 0.3);
        color: #ffffff;
        font-weight: 600;
        text-transform: uppercase;
        font-size: 13px;
        letter-spacing: 0.5px;
    }

    .cus-table tbody tr:hover {
        background: rgba(255, 255, 255, 0.05); /* Subtle hover effect on rows */
    }

    /* --- Mobile Responsive Table --- */
    @media screen and (max-width: 768px) {
        .cus-banner {
            padding: 24px 16px;
        }

        .cus-table thead {
            display: none; /* Hide headers on mobile */
        }

        .cus-table,
        .cus-table tbody,
        .cus-table tr,
        .cus-table td {
            display: block;
            width: 100%;
        }

        .cus-table tr {
            margin-bottom: 16px;
            background: rgba(0, 0, 0, 0.2);
            border-radius: 8px;
        }

        .cus-table td {
            text-align: right;
            padding-left: 50%;
            position: relative;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .cus-table td::before {
            content: attr(data-label);
            position: absolute;
            left: 16px;
            width: 45%;
            padding-right: 10px;
            white-space: nowrap;
            text-align: left;
            font-weight: 600;
            color: #93c5fd; /* Light blue for mobile headers */
        }
    }

    /* Force the text inside the banner to be white, overriding the theme defaults */
    .cus-banner,
    .cus-banner p,
    .cus-banner span.cus-teaser {
        color: #334155 !important;
    }

    a#cus-toggle-1 {
        color: #ffffff !important;
    }

    div#cus-banner-1 {
        border-left: 4px solid #fbbf24;
    }

    /* Remove the default link underline from the button */
    a.cus-toggle {
        text-decoration: none !important;
    }

    /* --- Tooltip Container --- */
    .cus-tooltip-container {
        position: relative; /* Crucial: Keeps the popup attached to this specific icon */
        display: inline-flex;
        align-items: center;
        cursor: pointer;
        margin: 0 8px; /* Slight spacing around the icon */
    }

    /* --- The Info Icon --- */
    .cus-info-icon {
        font-size: 18px;
        color: #94a3b8; /* Soft slate gray */
        transition: color 0.2s ease;
    }

    /* Change icon color on hover */
    .cus-tooltip-container:hover .cus-info-icon {
        color: #2563eb; /* Matches your brand blue */
    }

    /* --- The Tooltip Box (Hidden by Default) --- */
    .cus-tooltip-content {
        /* Hiding mechanism */
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px) translateX(-50%); /* Start slightly lower for a "slide up" effect */

        /* Positioning */
        position: absolute;
        bottom: 150%; /* Pushes it above the icon */
        left: 50%; /* Centers it relative to the icon */
        width: max-content; /* Allows box to size to text, bounded by max-width */
        max-width: 300px;
        z-index: 1000; /* Ensures it sits on top of other content */

        /* Styling */
        background-color: #1e293b; /* Dark, high-contrast background */
        color: #f8fafc; /* White text */
        padding: 14px 18px;
        border-radius: 8px;
        font-size: 12px;
        line-height: 1.5;
        font-family:
            system-ui,
            -apple-system,
            sans-serif;
        text-align: left;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);

        /* Smooth animation */
        transition:
            opacity 0.3s ease,
            visibility 0.3s ease,
            transform 0.3s ease;
        pointer-events: none; /* Prevents the tooltip itself from flickering if the mouse slips onto it */
    }

    /* --- The Tooltip Tail (The little triangle pointing down) --- */
    .cus-tooltip-content::after {
        content: "";
        position: absolute;
        top: 100%; /* Bottom of the box */
        left: 50%;
        margin-left: -6px; /* Centers the triangle */
        border-width: 6px;
        border-style: solid;
        border-color: #1e293b transparent transparent transparent; /* Matches dark background */
    }

    /* --- Link Styling Inside Tooltip --- */
    .cus-tooltip-content a {
        color: #60a5fa; /* Light blue link */
        text-decoration: underline;
    }

    .cus-tooltip-content a:hover {
        color: #93c5fd;
    }

    /* --- The Hover Reveal Trigger --- */
    .cus-tooltip-container:hover .cus-tooltip-content {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) translateX(-50%); /* Slides up into final position */
    }

    .nav-dropdown img {
