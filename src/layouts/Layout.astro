    /* Container: Creates a modern, centered card layout */
    figure.wp-block-image.is-style-res-img-back {
        display: flex;
        flex-direction: column;
        align-items: center;
        background-color: #ffffff;
        border: 1px solid #eaeaea;
        border-radius: 16px;
        padding: 32px 24px;
        max-width: 100%;
        margin: 20px auto;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease;
    }

    /* Hover effect for the card */
    figure.wp-block-image.is-style-res-img-back:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 35px rgba(0, 0, 0, 0.08);
    }

    /* Image: Styles the author photo into a neat circle with a subtle border */
    figure.wp-block-image.is-style-res-img-back img {
        border-radius: 50%;
        object-fit: cover;
        border: 3px solid #f0f4f8;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
        margin-bottom: 20px;
    }

    /* Caption: Enhances readability and typography for the bio text */
    figure.wp-block-image.is-style-res-img-back .wp-element-caption {
        font-family:
            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Oxygen-Sans,
            Ubuntu, Cantarell, "Helvetica Neue", sans-serif;
        font-size: 15px;
        line-height: 1.6;
        color: #4a5568;
        text-align: center;
        margin: 0;
        font-style: normal;
    }

    /* Optional: Emphasize the author's name if you wrap "Paige" in a strong tag later */
    figure.wp-block-image.is-style-res-img-back .wp-element-caption strong {
        color: #1a202c;
        font-weight: 600;
    }

