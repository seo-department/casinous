---
import MegaMenu from "../components/MegaMenu.astro"

export interface Props {
    title: string
    description?: string
    seoTitle?: string
    canonical?: string
    robots?: string
    keywords?: string
    author?: string
    ogImage?: string
}

const {
    title,
    description = "Your trusted guide to the fastest online casinos in the USA.",
    seoTitle,
    canonical,
    robots = "index, follow",
    keywords,
    author,
    ogImage = "/images/casinous-logo-usa-lg.png",
} = Astro.props

const finalTitle = seoTitle ? seoTitle : title
const canonicalURL = canonical || Astro.url.href
---

<!doctype html>
<html lang="en-US">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>{finalTitle}</title>
        <meta name="description" content={description} />
        {robots && <meta name="robots" content={robots} />}
        {keywords && <meta name="keywords" content={keywords} />}
        {author && <meta name="author" content={author} />}
        <link rel="canonical" href={canonicalURL} />

        <link rel="icon" type="image/png" href="/images/favicon-cus.png" />

        <!-- Open Graph -->
        <meta property="og:type" content="website" />
        <meta property="og:title" content={finalTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:site_name" content="Casino US" />

        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={finalTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        <link
            rel="preload"
            href="/css/all.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        />
        <noscript><link rel="stylesheet" href="/css/all.min.css" /></noscript>

        <link
            rel="preconnect"
            href="https://cdnjs.cloudflare.com"
            crossorigin
        />
        <link
            rel="preload"
            href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
            as="style"
            onload="this.onload=null;this.rel='stylesheet'"
        />
        <noscript>
            <link
                rel="stylesheet"
                href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css"
            />
        </noscript>
    </head>
    <body>
        <header class="header-bar">
            <div class="header-container">
                <div class="brand-group">
                    <a href="/" class="logo-link">
                        <div class="logo">
                            <img
                                src="/images/casinous-logo-usa-lg.png"
                                title="Casino us Online Casinos Logo"
                                alt="Casino us Online Casinos Logo"
                            />
                        </div>
                    </a>
                </div>

                <button
                    class="mobile-menu-toggle"
                    aria-label="Toggle navigation"
                >
                    <svg
                        class="icon-bars"
                        xmlns="http://www.w3.org/2000/svg"
                        width="30"
                        height="30"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#ffffff"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="3" y1="12" x2="21" y2="12"></line>
                        <line x1="3" y1="6" x2="21" y2="6"></line>
                        <line x1="3" y1="18" x2="21" y2="18"></line>
                    </svg>
                    <svg
                        class="icon-close"
                        style="display: none;"
                        xmlns="http://www.w3.org/2000/svg"
                        width="30"
                        height="30"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="#ffffff"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    >
                        <line x1="18" y1="6" x2="6" y2="18"></line>
                        <line x1="6" y1="6" x2="18" y2="18"></line>
                    </svg>
                </button>

                <div class="header-right">
                    <nav class="header-nav">
                        <MegaMenu />
                    </nav>
                </div>
            </div>
        </header>
        <main>
            <slot />
        </main>

        <footer class="footer-dark">
            <div class="footer-container">
                <div class="footer-section brand-section">
                    <a href="/" class="logo-link">
                        <div class="logo">
                            <!-- CASINO <span class="logo-highlight">US</span> -->
                            <img
                                src="/images/casinous-logo-usa-lg.png"
                                title="Casino us Online Casinos Logo"
                                alt="Casino us Online Casinos Logo"
                            />
                        </div>
                    </a>
                    <p>
                        Your trusted guide to the fastest, safest, and most
                        rewarding online casino experiences in the United States
                        for 2026.
                    </p>
                </div>

                <div class="footer-section links-section">
                    <strong>Quick Links</strong>
                    <ul>
                        <li><a href="/">Home</a></li>
                        <li><a href="/about-us/">About Us</a></li>
                        <li><a href="/contact-us/">Contact Us</a></li>
                    </ul>
                </div>

                <div class="footer-section links-section">
                    <strong>Legal & Support</strong>
                    <ul>
                        <li>
                            <a href="/terms-and-conditions/"
                                >Terms & Conditions</a
                            >
                        </li>
                        <li><a href="/privacy-policy/">Privacy Policy</a></li>
                        <li>
                            <a href="/responsible-gambling/"
                                >Responsible Gaming</a
                            >
                        </li>
                        <li>
                            <a href="/advertising-disclosure/"
                                >Advertising Disclosure</a
                            >
                        </li>
                        <li>
                            <a href="/gambling-addiction/">Gambling Addiction</a
                            >
                        </li>
                        <li>
                            <a href="/editorial-policy/">Editorial Policy</a>
                        </li>
                        <li>
                            <a href="/sitemap/">Sitemap</a>
                        </li>
                    </ul>
                </div>

                <div class="footer-section social-section">
                    <strong>Follow Us</strong>
                    <div class="social-icons">
                        <a
                            href="https://www.facebook.com/people/Casino-US/100092756866754/"
                            aria-label="Facebook"
                            ><i class="fa-brands fa-facebook-f"></i></a
                        >
                        <a
                            href="https://x.com/Real_CasinoUS"
                            aria-label="X (Twitter)"
                            ><i class="fa-brands fa-x-twitter"></i></a
                        >
                        <a
                            href="https://www.instagram.com/realcasino_us/"
                            aria-label="Instagram"
                            ><i class="fa-brands fa-instagram"></i></a
                        >
                        <a
                            href="https://www.youtube.com/@casinousus"
                            aria-label="YouTube"
                            ><i class="fa-brands fa-youtube"></i></a
                        >
                    </div>
                </div>
            </div>

            <div class="footer-bottom">
                <p>
                    &copy; {new Date().getFullYear()} Casino US. All rights reserved.
                </p>
            </div>
        </footer>
    </body>
</html>

<style is:global>
    .header-nav {
        gap: 14px !important;
    }
    .cus-vote-btn {
        transition: all 0.2s ease !important;
    }
    .cus-vote-btn:not(.active-vote):hover {
        background: #f3f4f6;
        transform: translateY(-1px);
    }
    .cus-vote-up.active-vote {
        color: #16a34a !important;
        border-color: #16a34a !important;
        background: #dcfce7 !important;
        cursor: default;
    }
    .cus-vote-down.active-vote {
        color: #dc2626 !important;
        border-color: #dc2626 !important;
        background: #fee2e2 !important;
        cursor: default;
    }
    .cus-casino-list-wrapper {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        max-width: 100%;
        margin: 2rem auto;
        font-family:
            -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica,
            Arial, sans-serif;
    }

    /* Grid Container Spacing */
    .tw-grid {
        gap: 20px !important;
        margin-bottom: 40px !important;
    }

    span.header-menu-icon_active {
        display: ruby !important;
    }

    /* Individual Card Styling */
    .tw-shadow-primary {
        box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05) !important;
        border: 1px solid #e5e7eb !important;
        background-color: #ffffff !important;
        border-radius: 8px !important;
        transition:
            transform 0.2s ease-in-out,
            box-shadow 0.2s ease-in-out !important;
    }

    /* Card Hover Effect */
    .tw-shadow-primary:hover {
        transform: translateY(-4px) !important;
        box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1) !important;
    }

    /* Button Wrapper Styling */

    /* Link/Text Styling Inside the Button */
    .tw-bg-colorset1 a {
        color: #ffffff !important;
        font-size: 15px !important;
        font-weight: 600 !important;
        text-decoration: none !important;
        padding: 12px 10px !important;
        display: block !important;
        transition: background-color 0.3s ease !important;
    }

    /* Button Hover State */
    .tw-bg-colorset1 a:hover {
        background-color: #1d4ed8 !important; /* Darker Blue on Hover */
        color: #ffffff !important;
    }

    p.has-text-align-left {
        position: relative !important;
        padding-left: 20px !important; /* Creates space for the bullet */
    }

    p.has-text-align-left::before {
        content: "\2022" !important; /* This is the CSS code for a bullet • */
        position: absolute !important;
        left: 0 !important;
        color: #2563eb !important; /* Change this hex code to make the bullet any color you want */
        font-size: 1.2em !important; /* Makes the bullet slightly larger */
        line-height: 1 !important;
    }

    .cus-casino-card {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        transition:
            box-shadow 0.2s ease,
            border-color 0.2s ease;
    }
    .cus-casino-card:hover {
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        border-color: #d1d5db;
    }
    .cus-card-body {
        display: flex;
        padding: 1.5rem;
        gap: 2rem;
        align-items: center;
    }
    .cus-col-logo {
        flex: 0 0 140px;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
    }
    @keyframes breathe {
        0% {
            transform: scale(1);
        }
        50% {
            transform: scale(1.08);
        }
        100% {
            transform: scale(1);
        }
    }
    .cus-casino-list-wrapper .cus-casino-card:first-child .cus-claim-btn {
        display: inline-block;
        animation: breathe 2s ease-in-out infinite;
    }
    .cus-card-footer {
        background: #f0f8ff;
        border-top: 1px solid #d5efdb;
    }
    .cus-logo-box {
        width: 100%;
        height: 100%;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 0.75rem;
        overflow: hidden;
    }
    .cus-col-logo {
        border-right: 1px solid #dcfde3;
    }
    strong.cus-bonus-title {
        font-size: 34px;
        margin-bottom: 19px !important;
        display: block;
    }

    .cus-rating {
        font-size: 0.9rem;
        font-weight: 700;
        color: #111827;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }
    .cus-rating i {
        color: #fbbf24;
    }
    .cus-more-info-btn {
        background: 0 0;
        border: none;
        color: #3b82f6;
        font-size: 0.8rem;
        font-weight: 500;
        margin-top: 0.5rem;
        cursor: pointer;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 0.25rem;
        transition: color 0.2s;
    }
    .cus-more-info-btn:hover {
        color: #2563eb;
    }
    .cus-col-details {
        flex: 1;
    }

    figure.alignright.size-full {
        float: right !important;
    }

    .cus-casino-header {
        display: flex;
        align-items: center;
        margin-bottom: 0.25rem;
    }
    .cus-casino-name {
        font-size: 0.9rem;
        color: #111827;
        font-weight: 500;
    }
    .cus-bonus-title {
        font-size: 1.25rem;
        font-weight: 700;
        color: #000;
        margin: 0 0 1rem 0;
        line-height: 1.4;
    }
    .cus-stats-row {
        display: flex;
        align-items: center;
        background: #e7f8f2;
        border-radius: 6px;
        padding: 0.5rem 1rem;
        gap: 1.5rem;
        border: 1px solid #f1f5f9;
    }
    .cus-stat-item {
        display: flex;
        flex-direction: row;
        gap: 0.5rem;
        font-size: 0.85rem;
    }
    .cus-stat-label {
        color: #000;
        font-weight: 700;
    }
    .cus-votes {
        display: none;
    }

    div#frequentlyaskedquestions {
        padding: 13px !important;
    }

    .tw-shadow-primary.tw-bg-white.tw-rounded-lg.tw-px-6.tw-py-5.tw-flex.tw-flex-col.tw-justify-between.tw-relative {
        padding: 12px !important;
        margin-bottom: 13px;
    }

    img,
    figure.wp-block-image img,
    .wp-block-image img {
        max-width: 100% !important;
        height: auto !important;
        display: block; /* Removes weird bottom spacing */
        box-sizing: border-box !important;
    }

    /* Fix for right/left aligned images that break narrow mobile columns */
    @media (max-width: 768px) {
        .alignright,
        .alignleft {
            float: none !important;
            margin-left: auto !important;
            margin-right: auto !important;
            text-align: center;
        }
    }

    @media (max-width: 768px) {
        /* Make sure the wrapper has enough bottom padding so the bar doesn't touch the cards */
        .crd-sd-wrapper {
            padding-bottom: 25px !important;
            scrollbar-width: thin !important; /* Enables thin scrollbar in Firefox */
            scrollbar-color: #cbd5e1 transparent !important; /* Firefox thumb and track color */
        }

        /* 1. Show and size the scrollbar */
        .crd-sd-wrapper::-webkit-scrollbar {
            display: block !important;
            height: 6px !important; /* Height of the horizontal scrollbar */
        }

        /* 2. Style the background track (the line the bar slides on) */
        .crd-sd-wrapper::-webkit-scrollbar-track {
            background: transparent !important;
            border-radius: 10px !important;
            margin: 0 20px !important; /* Keeps the track from touching the absolute edges of the screen */
        }

        /* 3. Style the moving "thumb" (the actual indicator) */
        .crd-sd-wrapper::-webkit-scrollbar-thumb {
            background: #cbd5e1 !important; /* Soft gray color for the indicator */
            border-radius: 10px !important;
        }

        /* Make the indicator slightly darker when the user is actively swiping */
        .crd-sd-wrapper::-webkit-scrollbar-thumb:active {
            background: #94a3b8 !important;
        }
    }

    #free-spin-terms-and-conditions > div.tw-bg-white {
        background-color: rgba(255, 255, 255, 0.02) !important;
        border: 1px solid rgba(255, 255, 255, 0.08) !important;
        border-radius: 16px !important;
        padding: 30px !important;
        margin-bottom: 24px !important;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2) !important;
        transition:
            transform 0.3s ease,
            box-shadow 0.3s ease,
            border-color 0.3s ease !important;
    }
    #free-spin-terms-and-conditions > div.tw-bg-white:hover {
        transform: translateY(-4px) !important;
        box-shadow: 0 8px 30px rgba(0, 0, 0, 0.4) !important;
        border-color: rgba(59, 130, 246, 0.3) !important;
    }
    #free-spin-terms-and-conditions > div.tw-bg-white > h3 {
        color: #000 !important;
        font-size: 24px !important;
        font-weight: 400 !important;
        margin-top: 0 !important;
        margin-bottom: 16px !important;
        padding-bottom: 16px !important;
        border-bottom: 1px solid rgba(255, 255, 255, 0.06) !important;
        display: flex !important;
        align-items: center !important;
    }
    #free-spin-terms-and-conditions > div.tw-bg-white > h3::before {
        content: "";
        display: inline-block;
        width: 4px;
        height: 22px;
        background-color: #3b82f6;
        margin-right: 12px;
        border-radius: 4px;
        box-shadow: 0 0 8px rgba(59, 130, 246, 0.6);
    }
    #free-spin-terms-and-conditions > div.tw-bg-white > p {
        color: #334155 !important;
        line-height: 1.8 !important;
        margin-bottom: 16px !important;
    }
    #free-spin-terms-and-conditions > div.tw-bg-white > p:last-of-type {
        margin-bottom: 0 !important;
    }
    #free-spin-terms-and-conditions > div.tw-bg-white > p a {
        color: #60a5fa !important;
        text-decoration: none !important;
        font-weight: 600 !important;
        transition: color 0.2s ease !important;
    }
    #free-spin-terms-and-conditions > div.tw-bg-white > p a:hover {
        color: #93c5fd !important;
        text-decoration: underline !important;
    }
    .cus-stat-value {
        color: #475569;
    }
    .cus-stat-divider {
        width: 1px;
        height: 15px;
        background: #cbd5e1;
    }
    .cus-col-action {
        flex: 0 0 200px;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .cus-promo-box {
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 0.4rem;
        text-align: center;
        background: #fff;
    }
    .cus-promo-label {
        font-size: 0.75rem;
        color: #4b5563;
        display: block;
        margin-bottom: 0.1rem;
    }
    .cus-promo-code {
        font-size: 1rem;
        font-weight: 700;
        color: #000;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        cursor: pointer;
    }
    .cus-claim-btn {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.4rem;
        background: #348a4c;
        color: #fff !important;
        font-weight: 600;
        text-decoration: none !important;
        padding: 0.85rem;
        border-radius: 6px;
        text-transform: uppercase;
        font-size: 0.95rem;
        transition: background 0.2s ease;
    }
    .cus-claim-btn:hover {
        background: #2a733f;
    }
    .cus-card-footer {
        padding: 0.75rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .cus-terms {
        font-size: 0.8rem;
        color: #4b5563;
    }
    .cus-votes {
        display: flex;
        gap: 0.5rem;
    }
    .cus-votes button {
        background: #fff;
        border: 1px solid #d1d5db;
        border-radius: 4px;
        padding: 0.2rem 0.5rem;
        font-size: 0.8rem;
        color: #4b5563;
        cursor: pointer;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }
    .cus-votes button:hover {
        background: #f3f4f6;
    }
    .cus-expanded-info {
        border-top: 1px solid #e5e7eb;
        padding: 1.5rem;
        background: #fff;
    }
    .cus-expanded-grid {
        display: grid;
        grid-template-columns: 280px 1fr;
        gap: 1rem;
    }
    .cus-expanded-stats {
        background: #f0f8ff;
        border-radius: 6px;
        padding: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }
    .cus-exp-stat {
        display: flex;
        justify-content: space-between;
        font-size: 0.85rem;
        border-bottom: 1px solid #e2e8f0;
        padding-bottom: 0.4rem;
    }
    .cus-exp-stat:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }
    .cus-exp-stat span {
        color: #111827;
        font-weight: 600;
    }
    .cus-exp-stat strong {
        color: #374151;
        font-weight: 400;
    }
    .cus-expanded-desc {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
        padding: 1rem;
    }
    .cus-expanded-desc strong {
        display: block;
        font-size: 0.9rem;
        color: #111827;
        margin-bottom: 0.5rem;
    }
    .cus-expanded-desc p {
        font-size: 0.85rem;
        color: #4b5563;
        line-height: 1.6;
        margin: 0;
    }
    @media (max-width: 850px) {
        .cus-card-body {
            flex-direction: column;
            text-align: center;
            padding: 1.25rem;
            gap: 1.25rem;
        }
        .cus-col-logo {
            width: 100%;
            flex: auto;
        }
        .cus-casino-header {
            justify-content: center;
        }
        .cus-stats-row {
            flex-direction: column;
            gap: 0.5rem;
            padding: 0.75rem;
        }
        .cus-stat-divider {
            display: none;
        }
        .cus-col-action {
            width: 100%;
            flex: auto;
        }
        .cus-expanded-grid {
            grid-template-columns: 1fr;
        }
        .cus-card-footer {
            flex-direction: column;
            gap: 0.75rem;
            text-align: center;
        }
    }
    :root {
        --bg-main: #f8fafc;
        --text-main: #334155;
        --heading-main: #1e293b;
        --accent-blue: #2563eb;
        --accent-light: #3b82f6;
    }
    html {
        scroll-behavior: smooth;
    }
    body {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family:
            system-ui,
            -apple-system,
            BlinkMacSystemFont,
            "Segoe UI",
            Roboto,
            sans-serif;
        background-color: var(--bg-main);
        color: var(--text-main);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
    }
    *,
    ::after,
    ::before {
        box-sizing: inherit;
    }
    main {
        flex-grow: 1;
        width: 100%;
    }
    .logo {
        color: #fff;
    }
    p.hero-intro-grey strong {
        color: #fff;
    }
    .header-bar {
        background-color: #1a233a;
        padding: 1.25rem 0;
        border-bottom: 1px solid #3a4459;
        position: sticky;
        top: 0;
        z-index: 100;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.02);
    }
    .header-container {
        max-width: 1356px;
        margin: 0 auto;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0 1.5rem;
    }
    .brand-group {
