    /* --- 3. Left Sidebar (Breaking Stories) --- */
    .breaking-story-card {
        display: flex;
        gap: 20px;
        padding: 16px 0;
        border-bottom: 1px solid #f1f5f9;
        transition: transform 0.2s ease;
    }

    .breaking-story-card:last-child {
