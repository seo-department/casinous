            <h2 class="section-title">
                <span class="title-accent"></span> Today's News
            </h2>
            <a href="/blog/" class="more-link">More &rarr;</a>
        </header>

        <section class="layout-main">
            <div class="left-col">
                {
                    mainPost && (
                        <article class="main-article">
                            <a
                                href={getRelativeUrl(mainPost.uri)}
                                class="image-wrapper-link"
                            >
                                <div class="image-wrapper">
                                    {mainPost.featuredImage?.node?.sourceUrl ? (
                                        <img
                                            src={cleanImageUrl(
                                                mainPost.featuredImage.node
                                                    .sourceUrl,
                                            )}
                                            srcset={cleanSrcSet(
                                                mainPost.featuredImage.node
                                                    .srcSet,
                                            )}
                                            sizes="(max-width: 1024px) 100vw, 800px"
                                            alt={
                                                mainPost.featuredImage.node
                                                    .altText || mainPost.title
                                            }
                                            loading="lazy"
                                            referrerpolicy="no-referrer"
                                        />
                                    ) : (
                                        <div class="placeholder-img">
                                            No Image
                                        </div>
                                    )}
                                    <span class="badge-breaking">Breaking</span>
                                </div>
                            </a>
                            <h1 class="article-title">
                                <a
                                    href={getRelativeUrl(mainPost.uri)}
                                    set:html={mainPost.title}
                                />
                            </h1>
                            <div class="meta">
                                <a
                                    href={getCategoryUrl(
                                        mainPost.categories?.nodes[0]?.slug,
                                    )}
