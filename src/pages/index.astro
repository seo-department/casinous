<Layout
    title={yoastTitle}
    seoTitle={yoastTitle}
    description={yoastDesc}
    schema={yoastSchema}
>
    <main class="news-portal-container">
        <nav class="nav-filters">
            <a href="#" class="nav-btn active">All News</a>
            <a href="/blog/" class="nav-btn">Blogs</a>
            {
                allCategories.map((cat: any) => {
                    // Skip rendering redundant categories
                    if (cat.slug === "blog" || cat.slug === "uncategorized")
                        return null
                    return (
                        <a href={getCategoryUrl(cat.slug)} class="nav-btn">
                            {cat.name}
                        </a>
                    )
                })
            }
        </nav>

