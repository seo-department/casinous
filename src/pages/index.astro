                                        "Editorial Team"}
                                </a>
                            </div>
                            <div
                                class="excerpt"
                                set:html={stripWp(mainPost.excerpt)}
                            />
                        </article>
                    )
                }

                <div class="sub-posts-grid">
                    {
                        subPosts.map((post: any) => (
                            <article class="sub-article">
                                <a href={getRelativeUrl(post.uri)}>
                                    {post.featuredImage?.node?.sourceUrl && (
                                        <img
                                            src={cleanImageUrl(
                                                post.featuredImage.node
                                                    .sourceUrl,
