        color: "#eab308",
    },
]

// Process Users for Team Section
let teamMembers = result.data?.users?.nodes || []

// Fallback to authors if WP 'users' query is empty
if (teamMembers.length === 0) {
    const uniqueAuthors = new Map()
    recentPosts.forEach((p: any) => {
        if (p.author?.node && !uniqueAuthors.has(p.author.node.name)) {
            uniqueAuthors.set(p.author.node.name, p.author.node)
        }
    })
    teamMembers = Array.from(uniqueAuthors.values())
}

// FILTER: Exclude authors named Tom and Sarah, limit to 8
teamMembers = teamMembers
    .filter((member: any) => {
        const fullName = (member.name || "").toLowerCase()
        const firstName = (member.firstName || "").toLowerCase()

        return (
            !fullName.includes("tom") &&
            !fullName.includes("sarah") &&
            !firstName.includes("tom") &&
            !firstName.includes("sarah")
        )
    })
    .slice(0, 8)
