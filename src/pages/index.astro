        <section class="team-grid">
            {
                teamMembers.map((member: any) => {
                    const displayName =
                        member.firstName && member.lastName
                            ? `${member.firstName} ${member.lastName}`
                            : member.name || "Editorial Team"

                    // 1. Generate the slug from the displayed name
                    const authorSlug = createAuthorSlug(displayName)
                    const avatar =
