<style>
	/* 1. Header Bar (Dark) */
	.header-bar {
		background-color: #1a233a;
		padding: 1rem 0;
		border-bottom: 1px solid #2d3748;
		color: white;
	}

	/* Container for the whole section */
	.info-content-section {
		max-width: 1100px;
		margin: 3rem auto;
		font-family:
			system-ui,
			-apple-system,
			sans-serif;
		color: #1e293b;
		padding: 0 2rem;
	}

	/* Typography Defaults */
	.info-content-section h2 {
		font-size: 1.8rem;
		font-weight: 800;
		color: #111827;
		margin-top: 0;
		margin-bottom: 1rem;
		letter-spacing: -0.5px;
	}

	.info-content-section h3 {
		font-size: 1.5rem;
		font-weight: 800;
		margin-top: 0;
		margin-bottom: 1rem;
		color: #ffffff;
	}

	.info-content-section p {
		line-height: 1.6;
		font-size: 1.05rem;
		color: #475569;
		margin: 0;
	}

	/* 1. Intro Grid Layout */
	.intro-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3rem;
		align-items: center;
	}

	.intro-text p strong {
		color: #1e293b;
	}

	/* Quote Box */
	.quote-box {
		background-color: #f4f8ff; /* Light blue tint */
		border-left: 4px solid #3b82f6; /* Blue left border */
		padding: 1.5rem 2rem;
		border-radius: 0.5rem;
	}

	.quote-box p {
		color: #1e40af; /* Darker blue text */
		font-style: italic;
		font-size: 1rem;
		line-height: 1.5;
	}

	/* Divider */
	.section-divider {
		border: 0;
		height: 1px;
		background-color: #e2e8f0;
		margin: 3rem 0;
	}

	/* 2. Takeaways Section */
	.takeaways-intro {
		margin-bottom: 2rem !important;
	}

	.highlight-blue {
		color: #2563eb;
		font-weight: 700;
	}

	.payout-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1rem;
	}

	.payout-card {
		background-color: #f8fafc;
		border-radius: 0.5rem;
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		gap: 0.75rem;
		color: #334155;
		font-size: 0.95rem;
	}

	.check-icon {
		color: #22c55e; /* Bright green */
		font-weight: bold;
		font-size: 1.1rem;
	}

	/* 3. Security Banner */
	.security-banner {
		background-color: #0f172a; /* Very dark blue */
		border-radius: 1rem;
		padding: 2.5rem 3rem;
		margin-top: 3rem;
		position: relative;
		overflow: hidden; /* Contains the decorative circle */
	}

	.security-content {
		position: relative;
		z-index: 2; /* Keeps text above the decoration */
		max-width: 90%;
	}

	.security-content p {
		color: #cbd5e1;
		font-size: 1rem;
	}

	.highlight-light-blue {
		color: #60a5fa;
		font-weight: 700;
	}

	/* The faint dark blue circle decoration on the bottom right */
	.banner-decoration {
		position: absolute;
		bottom: -50px;
		right: -50px;
		width: 250px;
		height: 250px;
		background-color: #1e293b;
		border-radius: 50%;
		opacity: 0.6;
		z-index: 1;
	}

	/* Mobile Responsiveness */
	@media (max-width: 768px) {
		.intro-grid {
			grid-template-columns: 1fr; /* Stack columns */
			gap: 2rem;
		}

		.payout-grid {
			grid-template-columns: 1fr; /* Stack cards */
		}

		.security-banner {
			padding: 2rem;
		}

		.security-content {
			max-width: 100%;
		}
	}

	.header-container {
		max-width: 1200px;
		margin: 0 auto;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 2rem;
	}

	.brand-group {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.brand-icon {
		width: 28px;
		height: 28px;
	}

	.logo {
		font-weight: 900;
		font-size: 1.2rem;
		letter-spacing: 0.5px;
	}

	/* Navigation Links */
	.header-nav {
		display: flex;
		gap: 2rem;
		align-items: center;
	}

	.header-nav a {
		color: #cbd5e1;
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 500;
		transition: color 0.2s ease;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.casino-card {
		margin-bottom: -18px;
	}

	.header-nav a:hover {
		color: #60a5fa;
	}

	/* 2. Hero Section (Very Dark) */
	.hero-section-dark {
		background-color: #242f46;
		padding: 1rem 0rem;
		color: white;
		text-align: center;
	}

	.hero-container {
		max-width: 100%;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.hero-section-dark h1 {
		font-size: 2.8rem;
		margin-top: 0;
		margin-bottom: 1.5rem;
		font-weight: 800;
	}

	.hero-intro-grey {
		font-size: 1.1rem;
		color: #cbd5e1;
		margin-bottom: 2rem;
		line-height: 1.6;
		max-width: 800px;
	}

	.verification-badges {
