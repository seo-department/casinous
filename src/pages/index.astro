		gap: 1.5rem;
		margin-bottom: 3rem;
	}

	.badge-item {
		color: white;
		font-size: 1rem;
		font-weight: 500;
	}

	.green-dot {
		color: #4ade80;
		margin-right: 0.2rem;
	}

	.meta-data-hero {
		display: flex;
		flex-wrap: wrap;
		gap: 2rem;
		justify-content: center;
		color: #94a3b8;
		font-size: 0.9rem;
		border-top: 1px solid #334155;
		padding-top: 1.5rem;
		width: 100%;
	}

	.author-block,
	.date-block {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.profile-icon {
		width: 1.5rem;
		height: 1.5rem;
		background-color: #475569;
		border-radius: 50%;
		display: inline-block;
	}

	.author-label {
		font-weight: 500;
		text-transform: uppercase;
		font-size: 0.8rem;
	}

	.author-name {
		font-weight: 700;
		color: white;
	}

	/* 3. Listings Section (White Cards, Grey Background) */
	.listings-section {
		background-color: #f1f5f9;
		padding: 4rem 2rem;
	}

	.listings-container {
		max-width: 1100px;
		margin: 0 auto;
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
	}

	.casino-card {
		background-color: #ffffff;
		border-radius: 0.75rem;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
		position: relative;
		border: 1px solid #e2e8f0;
	}

	.card-label {
		position: absolute;
		top: -15px;
		left: -15px;
		background-color: #1e293b;
		color: white;
		font-weight: 800;
		padding: 0.5rem 1rem;
		border-radius: 0.4rem;
		z-index: 10;
		font-size: 1rem;
	}

	.card-content {
