import Layout from "../layouts/Layout.astro"

// 1. Fetch Homepage SEO, 30 Posts, Users, AND Categories in a single GraphQL query
const wpUrl = "https://wordpress-1621926-6409582.cloudwaysapps.com/graphql"

const response = await fetch(wpUrl, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify({
        query: `
            query GetHomeData {
                nodeByUri(uri: "/") {
                    ... on Page {
                        title
                        seo {
                            title metaDesc schema { raw }
                        }
                    }
                }
                posts(first: 30) {
                    nodes {
                        uri
                        title
                        excerpt
                        date
                        featuredImage {
                            node {
                                sourceUrl
                                srcSet
                                altText
                            }
                        }
                        categories {
                            nodes {
                                name
                                slug
                            }
                        }
                        author {
                            node {
                                name
                                firstName
                                lastName
                                avatar { url }
                                slug
                            }
                        }
                    }
                }
                users(first: 10) {
                    nodes {
                        name
                        firstName
                        lastName
                        description
                        slug
                        avatar { url }
                    }
                }
                categories(first: 50) {
                    nodes {
                        name
                        slug
                    }
                }
            }
        `,
    }),
})

const result = await response.json()

if (result.errors) {
    console.error("❌ GRAPHQL ERROR:", JSON.stringify(result.errors, null, 2))
    throw new Error("WordPress rejected the GraphQL query.")
}

// --- 2. PROCESS SEO DATA ---
const page = result.data?.nodeByUri
const currentYear = new Date().getFullYear().toString()
const yoastTitle = (page?.seo?.title || page?.title || "Casino US").replaceAll(
    "[year]",
    currentYear,
)
const yoastDesc = (page?.seo?.metaDesc || "").replaceAll("[year]", currentYear)

const wpDomain = "https://wordpress-1621926-6409582.cloudwaysapps.com"
let yoastSchema = page?.seo?.schema?.raw || undefined
if (yoastSchema) {
    yoastSchema = yoastSchema.replaceAll(wpDomain, "https://www.casinous.com")
}

// --- 3. HELPER FUNCTIONS ---

const getCategoryUrl = (slug: string | undefined) => {
    if (!slug) return "#"
    // If the category is 'blog', route to /blog/ instead of /category/blog/
    if (slug === "blog") return "/blog/"
    return `/category/${slug}/`
}

const createAuthorSlug = (name: string | undefined) => {
    if (!name) return "editorial-team"
    return name
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/(^-|-$)+/g, "")
}

const cleanImageUrl = (url: string | undefined) => {
    if (!url) return "https://via.placeholder.com/300x150"
    try {
        const parsedUrl = new URL(url)
        return parsedUrl.pathname
    } catch (e) {
        return url
    }
}

const stripWp = (html: string | undefined) => {
    if (!html) return ""
    return html.replaceAll(wpDomain, "https://www.casinous.com")
}

const cleanSrcSet = (srcSet: string | undefined) => {
    if (!srcSet) return undefined
    return srcSet.replaceAll(wpDomain, "")
}
const getRelativeUrl = (uri: string | undefined) => {
    if (!uri) return "/"
    return `/${uri.replace(/https?:\/\/[^\/]+/g, "").replace(/^\/|\/$/g, "")}/`
}

const formatShortDate = (dateString: string) => {
    const options: Intl.DateTimeFormatOptions = {
        day: "numeric",
        month: "short",
        year: "numeric",
    }
    return new Date(dateString).toLocaleDateString("en-GB", options)
}

const stripHtml = (html: string) => {
    return html.replace(/<[^>]*>?/gm, "").replace(/\[&hellip;\]/g, "...")
}

// --- 4. DATA SLICING FOR DYNAMIC SECTIONS ---
const recentPosts = result.data?.posts?.nodes || []
const allCategories = result.data?.categories?.nodes || []

// Distribute the 30 posts across the different homepage blocks
const mainPost = recentPosts[0] || null
const subPosts = recentPosts.slice(1, 5)
const popularPosts = recentPosts.slice(1, 10)
const inDepthPosts = recentPosts.slice(10, 14)
const moreNewsPosts = recentPosts.slice(14, 21)
const guidePosts = recentPosts.slice(21, 25)
const qaPosts = recentPosts.slice(25, 30)

const manualFaqs = [
