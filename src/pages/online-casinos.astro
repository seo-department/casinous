			0 4px 6px -2px rgba(0, 0, 0, 0.05);

		/* Animation defaults */
		opacity: 0;
		visibility: hidden;
		transform: translateY(-5px);
		transition:
			opacity 0.3s ease,
			transform 0.3s ease,
			visibility 0.3s ease;
		z-index: 100; /* Keeps it above your casino cards */
	}

	/* The little triangle pointing up to the icon */
	.cus-tooltip-content::before {
		content: "";
		position: absolute;
		top: -6px;
		left: 6px; /* Adjust this to center the arrow under the icon */
		width: 10px;
		height: 10px;
		background-color: #ffffff;
		border-top: 1px solid #e2e8f0;
		border-left: 1px solid #e2e8f0;
		transform: rotate(45deg);
	}

	/* Show the tooltip on hover */
	.cus-tooltip-container:hover .cus-tooltip-content {
		opacity: 1;
		visibility: visible;
		transform: translateY(0);
	}

