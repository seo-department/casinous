	</header>

	<main class="home-wrapper" id="content">
		<article class="home-container wp-content" set:html={fixedContent} />
	</main>

	{
		recentPosts.length >= 4 && (
			<section class="full-width-discovery-section">
				<div class="discovery-container">
					<div class="discovery-columns">
						<div class="discovery-left-col">
							<h2 class="discovery-section-title">
								Read today's breaking stories
							</h2>
							<div class="breaking-stories-list">
								{breakingStories.map((story: any) => {
									// 🚨 FIX: Bulletproof Regex cleanly removes any domain to make the link relative
									let relativeUri = story.uri
										? story.uri.replace(
												/https?:\/\/[^\/]+/g,
												"",
											)
										: "/"
									const cleanSlug = relativeUri.replace(
										/^\/|\/$/g,
										"",
									)
									const storyLink = `/${cleanSlug}/`

									const storyDate = new Date(
										story.date,
									).toLocaleDateString("en-US", {
										year: "numeric",
										month: "short",
										day: "numeric",
									})

									let storyImage =
										story.featuredImage?.node?.sourceUrl ||
										"https://via.placeholder.com/300x150"

									// 🚨 BULLETPROOF FIX: Extract only the path so Vercel proxies the image
									try {
										const parsedUrl = new URL(storyImage)
										storyImage = parsedUrl.pathname
									} catch (e) {}

									const authorObj = story.author?.node
									const recAuthorName = authorObj
										? authorObj.firstName &&
											authorObj.lastName
											? `${authorObj.firstName} ${authorObj.lastName}`
											: authorObj.name
										: "Editorial Team"
									let recAuthorAvatar =
										authorObj?.avatar?.url ||
										`https://ui-avatars.com/api/?name=${encodeURIComponent(recAuthorName)}&background=f1f5f9&color=1e293b&bold=true`

									return (
										<div class="breaking-story-card">
											<div class="breaking-story-image">
												<a
													href={storyLink}
													class="thumbnail-link"
												>
													<img
														src={storyImage}
														alt={
															story.featuredImage
																?.node
																?.altText ||
															story.title
														}
														loading="lazy"
														referrerpolicy="no-referrer"
													/>
												</a>
											</div>
											<div class="breaking-story-content">
												<div class="card-meta-top">
													<span class="card-category">
														News
													</span>
													<span class="card-date">
														{storyDate}
													</span>
												</div>
												<a
													href={storyLink}
													class="card-title-link"
												>
													<h3
														set:html={story.title}
													/>
												</a>
												<div class="card-meta-bottom">
													<img
														src={recAuthorAvatar}
														alt={recAuthorName}
														class="card-author-avatar"
													/>
													<span>
														{recAuthorName} • 10 min
														read
													</span>
												</div>
											</div>
										</div>
									)
								})}
							</div>
						</div>

						<div class="discovery-right-col">
							<h2 class="discovery-section-title">
								Discover our blogs
							</h2>
							<div class="discover-blogs-list">
								{blogPosts.map((blogPost: any) => {
									// 🚨 FIX: Bulletproof Regex cleanly removes any domain to make the link relative
									let relativeUri = blogPost.uri
										? blogPost.uri.replace(
												/https?:\/\/[^\/]+/g,
												"",
											)
										: "/"
									const cleanSlug = relativeUri.replace(
										/^\/|\/$/g,
										"",
									)
									const blogLink = `/${cleanSlug}/`

									const blogDate = new Date(
										blogPost.date,
									).toLocaleDateString("en-US", {
										year: "numeric",
										month: "short",
										day: "numeric",
									})

									let blogImage =
										blogPost.featuredImage?.node
											?.sourceUrl ||
										"https://via.placeholder.com/150"

									// 🚨 BULLETPROOF FIX: Use JS URL object to force the Cloudways domain
									// 🚨 BULLETPROOF FIX: Extract only the path so Vercel proxies the image
									try {
										const parsedUrl = new URL(blogImage)
										blogImage = parsedUrl.pathname
									} catch (e) {}

									const authorObj = blogPost.author?.node
									const blogAuthorName = authorObj
										? authorObj.firstName &&
											authorObj.lastName
											? `${authorObj.firstName} ${authorObj.lastName}`
											: authorObj.name
										: "Editorial Team"
									let blogAuthorAvatar =
										authorObj?.avatar?.url ||
										`https://ui-avatars.com/api/?name=${encodeURIComponent(blogAuthorName)}&background=f1f5f9&color=1e293b&bold=true`

									return (
										<div class="blog-post-card">
											<div class="blog-post-image">
												<a href={blogLink}>
													<img
														src={blogImage}
														alt={
															blogPost
																.featuredImage
																?.node
																?.altText ||
															blogPost.title
														}
														loading="lazy"
														referrerpolicy="no-referrer"
													/>
												</a>
											</div>
											<div class="blog-post-content">
												<a
													href={blogLink}
													class="blog-title-link"
												>
													<h3
														set:html={
															blogPost.title
														}
													/>
												</a>
												<div class="blog-meta">
													<div class="blog-meta-author">
														<img
															src={
																blogAuthorAvatar
															}
															alt={blogAuthorName}
															class="blog-author-avatar"
														/>
														<span>
															{blogAuthorName} •{" "}
															{blogDate}
														</span>
													</div>
													<a
														href={blogLink}
														class="blog-read-more"
													>
														Read{" "}
														<i class="fa-solid fa-arrow-right" />
													</a>
												</div>
											</div>
										</div>
									)
								})}
							</div>
						</div>
					</div>
				</div>
			</section>
		)
	}
</Layout>

<script is:inline>
	// JS Logic to Toggle the Auto TOC
	window.toggleToc = function () {
		const body = document.getElementById("tocBody")
		const arrow = document.querySelector(".toc-arrow")
		if (body.style.display === "block") {
			body.style.display = "none"
			if (arrow) arrow.style.transform = "rotate(0deg)"
		} else {
			body.style.display = "block"
			if (arrow) arrow.style.transform = "rotate(180deg)"
		}
	}

	// FIX: Explictly check visibility state so it never gets confused
	window.toggleCustomBlock = function (btn, targetId) {
		const hiddenBlock = document.getElementById(targetId)
		if (!hiddenBlock) return

		const isVisible =
			window.getComputedStyle(hiddenBlock).display === "block"

		if (isVisible) {
			// Collapse
			hiddenBlock.style.display = "none"
			btn.innerHTML = 'Show More <i class="fa-solid fa-chevron-down"></i>'
			btn.setAttribute("aria-expanded", "false")
		} else {
			// Expand
			hiddenBlock.style.display = "block"
			btn.innerHTML = 'Show Less <i class="fa-solid fa-chevron-up"></i>'
			btn.setAttribute("aria-expanded", "true")
		}
	}

	// FIX: New toggle for the Disclaimer Block
	window.toggleContent = function (btn) {
		const container = btn.closest(".disclaimer-cl")
		const content = container.querySelector(".content1")
		if (!content) return

		const isVisible = window.getComputedStyle(content).display === "block"

		if (isVisible) {
			// Collapse
			content.style.display = "none"
			btn.innerHTML = 'Show More <i class="fa-solid fa-chevron-down"></i>'
		} else {
			// Expand
			content.style.display = "block"
			btn.innerHTML = 'Show Less <i class="fa-solid fa-chevron-up"></i>'
		}
	}
</script>

