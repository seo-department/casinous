---
import Layout from "../layouts/Layout.astro"

// 1. Fetch BOTH the /online-casinos/ content AND the 8 recent posts in a single GraphQL query
const wpUrl = "https://wordpress-1621926-6409582.cloudwaysapps.com/graphql"

const response = await fetch(wpUrl, {
	method: "POST",
	headers: { "Content-Type": "application/json" },
	body: JSON.stringify({
		query: `
            query GetOnlineCasinosAndPosts {
                nodeByUri(uri: "/online-casinos/") {
                    ... on Page {
                        title
                        content
                        date
                        modified
                        seo {
                            title metaDesc focuskw canonical metaRobotsNoindex metaRobotsNofollow schema { raw }
                        }
                        author {
                            node {
                                name
                                firstName
                                lastName
                                avatar { url }
                                seo { social { facebook twitter instagram linkedIn } }
                            }
                        }
                    }
                }
                posts(first: 8) {
                    nodes {
                        uri
                        title
                        excerpt
                        date
                        featuredImage {
                            node {
                                sourceUrl
                                altText
                            }
                        }
                        author {
                            node {
                                name
                                firstName
                                lastName
                                avatar { url }
                            }
                        }
                    }
                }
            }
        `,
	}),
})

const result = await response.json()

if (result.errors) {
	console.error("❌ GRAPHQL ERROR:", JSON.stringify(result.errors, null, 2))
	throw new Error("WordPress rejected the GraphQL query.")
}

// --- 2. PROCESS PAGE DATA ---
const page = result.data?.nodeByUri
const currentYear = new Date().getFullYear().toString()
const yoastTitle = (page?.seo?.title || page?.title || "Casino US").replaceAll(
	"[year]",
	currentYear,
)
const yoastDesc = (page?.seo?.metaDesc || "").replaceAll("[year]", currentYear)

// 🚨 FIX: Updated to match your new Cloudways App URL
const wpDomain = "https://wordpress-1621926-6409582.cloudwaysapps.com"

// Extract and clean the Schema so it uses the live domain
const liveDomain = "https://www.casinous.com"
const pageUrl = `${liveDomain}/online-casinos/`

let yoastSchema = page?.seo?.schema?.raw || undefined
if (yoastSchema) {
	yoastSchema = yoastSchema.replaceAll(wpDomain, liveDomain)

	try {
		const schemaObj = JSON.parse(yoastSchema)

		// Make sure @graph exists and is an array; if not, wrap what we have
		if (!Array.isArray(schemaObj["@graph"])) {
			schemaObj["@graph"] = schemaObj["@type"] ? [schemaObj] : []
		}

		const graph = schemaObj["@graph"]
		const existingTypes = graph.map((n: any) => n["@type"])

		const extraNodes = [
			{
				"@type": "WPHeader",
				"@id": `${pageUrl}#header`,
				isPartOf: { "@id": pageUrl },
			},
			{
				"@type": "WPFooter",
				"@id": `${pageUrl}#footer`,
				isPartOf: { "@id": pageUrl },
			},
			{
				"@type": "CreativeWork",
				"@id": `${pageUrl}#creativework`,
				name: yoastTitle,
				headline: yoastTitle,
				description: yoastDesc,
				url: pageUrl,
				datePublished: page?.date || undefined,
				dateModified: page?.modified || page?.date || undefined,
				isPartOf: { "@id": pageUrl },
			},
			// --- NEW: WebPage Schema ---
			{
				"@type": "WebPage",
				"@id": `${pageUrl}#webpage`,
				url: pageUrl,
				name: yoastTitle,
				description: yoastDesc,
				datePublished: page?.date || undefined,
				dateModified: page?.modified || page?.date || undefined,
				isPartOf: { "@id": `${liveDomain}/#website` },
				inLanguage: "en-US",
			},
		]

		for (const node of extraNodes) {
			const existingIndex = graph.findIndex(
				(n: any) => n["@type"] === node["@type"],
			)
			if (existingIndex > -1) {
				// Override Yoast's default node with your custom one
				graph[existingIndex] = { ...graph[existingIndex], ...node }
			} else {
				// Inject as new if it doesn't exist
				graph.push(node)
			}
		}

		// Rebuild wrapper preserving @context
		yoastSchema = JSON.stringify({
			"@context": schemaObj["@context"] || "https://schema.org",
			"@graph": graph,
		})
	} catch (e) {
		console.error("Schema injection failed:", e)
	}
}

// Hero Meta Data (Author)
const authorObj = page?.author?.node
const authorName = authorObj
	? authorObj.firstName && authorObj.lastName
		? `${authorObj.firstName} ${authorObj.lastName}`
		: authorObj.name
	: "Editorial Team"
let authorAvatar =
	authorObj?.avatar?.url ||
	`https://ui-avatars.com/api/?name=${encodeURIComponent(authorName)}&background=f1f5f9&color=1e293b&bold=true`
const authorSlug = authorName
	.toLowerCase()
	.replace(/[^a-z0-9]+/g, "-")
	.replace(/(^-|-$)+/g, "")
const authorLink = `/about-us/${authorSlug}/`

// Author Social Links
const authorSocials = authorObj?.seo?.social || {}
const formatSocial = (value: string | undefined, domain: string) => {
	if (!value) return null
	return value.startsWith("http")
		? value
		: `${domain}${value.replace(/^@/, "")}`
}
const authorTwitter = formatSocial(
	authorSocials.twitter,
	"https://twitter.com/",
)
const authorFacebook = formatSocial(
	authorSocials.facebook,
	"https://facebook.com/",
)
const authorInstagram = formatSocial(
	authorSocials.instagram,
	"https://instagram.com/",
)
const authorLinkedIn = formatSocial(
	authorSocials.linkedIn,
	"https://linkedin.com/in/",
)

// Reviewer Data
const reviewerName = "Kylie Johnston"
const reviewerAvatar =
	"https://secure.gravatar.com/avatar/6a14bc8cd1f9dccc295508e407cc155adc20c6da88d2ca69ae89d86b917750a9?s=150&d=mm&r=g"
const reviewerSlug = reviewerName
	.toLowerCase()
	.replace(/[^a-z0-9]+/g, "-")
	.replace(/(^-|-$)+/g, "")
const reviewerLink = `/about-us/${reviewerSlug}/`

const rawDate = page?.modified || page?.date || new Date().toISOString()
const formattedDate = new Date(rawDate).toLocaleDateString("en-US", {
	year: "numeric",
	month: "short",
	day: "numeric",
})

// Clean the WordPress Content
const rawContent = page?.content || ""
let fixedContent = rawContent
	.replace(/<h1[^>]*>[\s\S]*?<\/h1>/gi, "")
	.replace(/src="[^"]*placeholder[^"]*"/gi, "")
	.replaceAll('data-src="/wp-content/', 'src="/wp-content/')
	.replaceAll('data-srcset="/wp-content/', 'srcset="/wp-content/')

	// 🚨 BULLETPROOF FIX: Globally strip the Cloudways domain from the entire HTML string.
	.replaceAll(wpDomain, "")

	.replaceAll("<img ", '<img referrerpolicy="no-referrer" ')
	.replace(/<p>\s*(&nbsp;)?\s*<\/p>/gi, "")
	.replace(
		/<strong>\s*Ranking of the Best Payment Methods\s*<\/strong>/gi,
		"",
	)
	.replaceAll("[year]", currentYear)

// --- Auto Table of Contents Generation ---
let tocListItems = ""
let h2Counter = 0

// Parse H2s to inject IDs and build TOC items
let contentWithIds = fixedContent.replace(
	/<h2([^>]*)>(.*?)<\/h2>/gi,
	(match, attrs, content) => {
		h2Counter++
		// Clean tags from content to create a readable slug
		const cleanText = content.replace(/<[^>]*>?/gm, "").trim()
		const slug = cleanText
			.toLowerCase()
			.replace(/[^a-z0-9]+/g, "-")
			.replace(/(^-|-$)+/g, "")

		// Inject ID if it doesn't already exist
		const newAttrs = attrs.includes("id=")
			? attrs
			: ` id="${slug}" ${attrs}`
		tocListItems += `<li><a href="#${slug}">${cleanText}</a></li>`

		return `<h2${newAttrs}>${content}</h2>`
	},
)

let tocHtml = ""
if (h2Counter > 0) {
	tocHtml = `
    <div class="toc-wrapper cus-toc">
        <div class="toc-header" onclick="toggleToc()">
            Table of Contents <i class="fa-solid fa-chevron-down toc-arrow"></i>
        </div>
        <div class="toc-body" id="tocBody">
            <ul>
                ${tocListItems}
            </ul>
        </div>
    </div>`
}

// Inject TOC where the shortcode is, OR at the very top if no shortcode exists
if (contentWithIds.includes("[casino_toc]")) {
	fixedContent = contentWithIds
		.replace(/<p>\s*\[casino_toc\]\s*<\/p>/gi, tocHtml)
		.replaceAll("[casino_toc]", tocHtml)
} else {
	fixedContent = tocHtml + contentWithIds
}

// --- 3. PROCESS RECENT POSTS (For Breaking News Section) ---
const recentPosts = result.data?.posts?.nodes || []
const breakingStories = recentPosts.slice(0, 3)
const blogPosts = recentPosts.slice(3, 7)
---

<Layout
	title={yoastTitle}
	seoTitle={yoastTitle}
	description={yoastDesc}
	schema={yoastSchema}
>
	<header class="home-hero new-split-hero">
		<div class="home-hero-container">
			<div class="hero-columns">
				<div class="hero-left">
					<h1
