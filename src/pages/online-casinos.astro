									</a>
								)
							}
							{
								authorFacebook && (
									<a
										href={authorFacebook}
										target="_blank"
										rel="noopener noreferrer"
										class="amb-social facebook"
									>
										<i class="fa-brands fa-facebook-f" />
									</a>
								)
							}
							{
								authorInstagram && (
