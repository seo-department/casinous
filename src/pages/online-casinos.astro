		box-shadow: 0 2px 5px rgba(0, 0, 0, 0.05);
	}

	/* Content Box Outline */
	.top-mu-cus-content-box {
		background-color: #ffffff;
		border: 1px solid #e2e8f0;
		border-radius: 12px;
		padding: 2.5rem;
