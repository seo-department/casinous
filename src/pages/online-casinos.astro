<script>
	document.addEventListener("DOMContentLoaded", () => {
		const tabs = document.querySelectorAll(".top-mu-cus-tab")
		const contents = document.querySelectorAll(".top-mu-cus-content")

		tabs.forEach(tab => {
			tab.addEventListener("click", () => {
				// Remove active class from all tabs and contents
				tabs.forEach(t => t.classList.remove("active"))
				contents.forEach(c => c.classList.remove("active"))

				// Add active class to clicked tab (using 'tab' instead of 'this')
				tab.classList.add("active")

				// Find target ID and show corresponding content
				const targetId = tab.getAttribute("data-target")
				if (targetId) {
					const targetContent = document.getElementById(targetId)
					if (targetContent) {
						targetContent.classList.add("active")
					}
				}
			})
		})
	})
</script>

<script>
	// JS Logic for the Horizontal Bonus Slider
	document.addEventListener("DOMContentLoaded", () => {
		const sliderWrapper = document.getElementById("crd-sd-wrapper")
		const leftArrow = document.getElementById("left-arrow")
		const rightArrow = document.getElementById("right-arrow")

		if (sliderWrapper && leftArrow && rightArrow) {
			// Scroll roughly one card width + the gap
			const scrollAmount = 280

			leftArrow.addEventListener("click", () => {
				sliderWrapper.scrollBy({
					left: -scrollAmount,
					behavior: "smooth",
				})
			})

			rightArrow.addEventListener("click", () => {
				sliderWrapper.scrollBy({
					left: scrollAmount,
					behavior: "smooth",
				})
			})
		}
	})
</script>

<script>
	document.addEventListener("DOMContentLoaded", () => {
		const faqQuestions = document.querySelectorAll(".faq-question")

		faqQuestions.forEach(question => {
			question.addEventListener("click", () => {
				const currentItem = question.closest(".faq-item")
				const isExpanded =
					question.getAttribute("aria-expanded") === "true"

				// Optional: Close all other FAQs when one is clicked (Accordion style)
				document.querySelectorAll(".faq-item").forEach(item => {
					item.classList.remove("active")
					// Added ? below to prevent TS null errors
					item.querySelector(".faq-question")?.setAttribute(
						"aria-expanded",
						"false",
					)
				})

				// Toggle the clicked FAQ
				if (!isExpanded) {
					// Added ? below
					currentItem?.classList.add("active")
					question.setAttribute("aria-expanded", "true")
				} else {
					// Added ? below
					currentItem?.classList.remove("active")
					question.setAttribute("aria-expanded", "false")
				}
			})
		})
	})
</script>

