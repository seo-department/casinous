---
import { Image } from "astro:assets"
import Layout from "../layouts/Layout.astro"

// 1. Fetch data from WordPress (Posts AND Pages)
export async function getStaticPaths() {
    // 🚨 1. SINGLE SOURCE OF TRUTH FOR THE DOMAIN
    const APP_ID = "6409582"
    const wpDomain = `https://wordpress-1621926-${APP_ID}.cloudwaysapps.com`
    const wpUrl = `${wpDomain}/graphql`

    let allNodes: any[] = []
    let allPostsList: any[] = []

    // --- FETCH POSTS ---
    let hasNextPosts = true
    let postsCursor = null

    while (hasNextPosts) {
        const response = await fetch(wpUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                query: `
                    query GetPosts($after: String) {
                        posts(first: 70, after: $after) {
                            pageInfo { hasNextPage endCursor }
                            nodes {
                                uri title content date modified
                                featuredImage { node { sourceUrl altText } }
                                author { node { name firstName lastName uri url avatar { url } seo { social { facebook twitter instagram linkedIn } } } }
                                seo { 
                                    title metaDesc focuskw canonical metaRobotsNoindex metaRobotsNofollow schema { raw } 
                                    breadcrumbs {
                                        text
                                        url
                                    }
                                }
                            }
                        }
                    }
                `,
                variables: { after: postsCursor },
            }),
        })

        const result = await response.json()

        if (result.errors) {
            console.error(
                "❌ GRAPHQL POSTS ERROR:",
                JSON.stringify(result.errors, null, 2),
            )
            throw new Error("WordPress rejected the GraphQL query for posts.")
        }

        if (!result?.data?.posts?.nodes) {
            console.error(
                "❌ UNEXPECTED POSTS RESPONSE:",
                JSON.stringify(result, null, 2),
            )
            throw new Error(
                `GraphQL succeeded, but 'posts' are missing. URL: ${wpUrl}`,
            )
        }

        const postsData = result.data.posts.nodes.map((node: any) => ({
            ...node,
            contentType: "post",
        }))
        allNodes.push(...postsData)
        allPostsList.push(...postsData)

        hasNextPosts = result.data.posts.pageInfo.hasNextPage
        postsCursor = result.data.posts.pageInfo.endCursor
    }

    // --- FETCH PAGES ---
    let hasNextPages = true
    let pagesCursor = null

    while (hasNextPages) {
        const response = await fetch(wpUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({
                query: `
                    query GetPages($after: String) {
                        pages(first: 70, after: $after) {
                            pageInfo { hasNextPage endCursor }
                            nodes {
                                uri title content date modified
                                featuredImage { node { sourceUrl altText } }
                                author { node { name firstName lastName uri url avatar { url } seo { social { facebook twitter instagram linkedIn } } } }
                                seo { 
                                    title metaDesc focuskw canonical metaRobotsNoindex metaRobotsNofollow schema { raw } 
                                    breadcrumbs {
                                        text
                                        url
                                    }
                                }
                            }
                        }
                    }
                `,
                variables: { after: pagesCursor },
            }),
        })

        const result = await response.json()

        if (result.errors) {
            console.error(
                "❌ GRAPHQL PAGES ERROR:",
                JSON.stringify(result.errors, null, 2),
            )
            throw new Error("WordPress rejected the GraphQL query for pages.")
        }

        if (!result?.data?.pages?.nodes) {
            console.error(
                "❌ UNEXPECTED PAGES RESPONSE:",
                JSON.stringify(result, null, 2),
            )
            throw new Error(
                `GraphQL succeeded, but 'pages' are missing. URL: ${wpUrl}`,
            )
        }

        const pagesData = result.data.pages.nodes.map((node: any) => ({
            ...node,
            contentType: "page",
        }))
        allNodes.push(...pagesData)

        hasNextPages = result.data.pages.pageInfo.hasNextPage
        pagesCursor = result.data.pages.pageInfo.endCursor
    }

    // --- FILTER AND RETURN ---
    const sanitizeSlug = (uri: string) => {
        if (!uri) return ""
        let clean = uri.replace(/https?:\/+www\.casinous\.com/gi, "")
        clean = clean.replace(
            /https?:\/+wordpress-[a-zA-Z0-9-]+\.cloudwaysapps\.com/gi,
            "",
        )
        clean = clean.replace(/https?:[\/]+/gi, "")
        clean = clean.replace(/[:\\]/g, "")
        clean = clean.replace(/\/+/g, "/")
        return clean.replace(/^\/|\/$/g, "")
    }

    const validNodes = allNodes.filter((node: any) => {
        if (!node.uri || node.uri === "/") return false
        if (node.uri.includes("http") || node.uri.includes("casinous.com")) {
            return false
        }
        return true
    })

    // Grab 8 recent posts total to divide between the two sections later
    const recentPosts = allPostsList.slice(0, 8)

    return validNodes.map((node: any) => {
        const cleanSlug = sanitizeSlug(node.uri)

        // Give the page/post 7 total related items to match the homepage layout
        const related =
            node.contentType === "post"
                ? recentPosts.filter(p => p.uri !== node.uri).slice(0, 7)
                : []

        return {
            params: { slug: cleanSlug || undefined },
            props: {
                post: node,
                contentType: node.contentType,
                relatedPosts: related,
            },
        }
    })
}

// 2. Define the Props Interface
interface Props {
    contentType: "post" | "page"
    relatedPosts: any[]
    post: any
}

const { post, contentType, relatedPosts } = Astro.props
const { slug } = Astro.params

// 🚨 SPLIT THE POSTS FOR THE FOOTER LAYOUT
const breakingStories = relatedPosts.slice(0, 3)
const blogPosts = relatedPosts.slice(3, 7)

const isPost = contentType === "post"
const isPage = contentType === "page"

const pathSegments = slug?.split("/") || []
const category = pathSegments.length > 1 ? pathSegments[0] : "guide"
const cleanCategoryName = category.replace(/-/g, " ")

const currentYear = new Date().getFullYear().toString()

const yoastTitle = (post.seo?.title || post.title || "").replaceAll(
    "[year]",
    currentYear,
)
const yoastDesc = (post.seo?.metaDesc || "").replaceAll("[year]", currentYear)

// 🚨 FIX: Swap the Cloudways domain and fix the uncategorized path in the Schema
let yoastSchema = post.seo?.schema?.raw || undefined
if (yoastSchema) {
    yoastSchema = yoastSchema
        .replaceAll("https://wordpress-1621926-6409582.cloudwaysapps.com", "https://www.casinous.com")
        .replaceAll("/uncategorized/", "/blog/")
}

// 🚨 FIX: Force the Yoast canonical URL to use the live domain AND fix the uncategorized path
let canonicalUrl = post.seo?.canonical || undefined;
if (canonicalUrl) {
    canonicalUrl = canonicalUrl
        .replace("https://wordpress-1621926-6409582.cloudwaysapps.com", "https://www.casinous.com")
        .replace("/uncategorized/", "/blog/");
}
const focusKeyword = post.seo?.focuskw || undefined

// 🚨 Extract and clean Yoast Breadcrumbs
const rawBreadcrumbs = post.seo?.breadcrumbs || []
const yoastBreadcrumbs = rawBreadcrumbs.map((crumb: any, index: number) => {
    let cleanUrl = crumb.url || "/"
    
    // Strip both the live domain and the Cloudways domain to make links relative
    cleanUrl = cleanUrl.replace(/https?:\/\/(www\.)?casinous\.com/gi, "")
    cleanUrl = cleanUrl.replace(/https?:\/+wordpress-[a-zA-Z0-9-]+\.cloudwaysapps\.com/gi, "")
    // Fix uncategorized breadcrumb paths
    cleanUrl = cleanUrl.replace("/uncategorized/", "/blog/")
    
    if (cleanUrl === "") cleanUrl = "/"

    const isLastItem = index === rawBreadcrumbs.length - 1;

    // Override the text with the Focus Keyword if it is the last item in the chain
    let displayText = crumb.text;
    if (isLastItem && focusKeyword) {
        // Capitalize the first letter so it looks like a proper title
        displayText = focusKeyword.charAt(0).toUpperCase() + focusKeyword.slice(1);
    }

    return {
        text: displayText,
        url: cleanUrl,
        isLast: isLastItem
    }
})

const noindex = post.seo?.metaRobotsNoindex || "index"
const nofollow = post.seo?.metaRobotsNofollow || "follow"
const robotsTag = `${noindex}, ${nofollow}`

// 5. Author Data Extraction
const wpDomain = "https://wordpress-1621926-6409582.cloudwaysapps.com"
const authorNode = post.author?.node
const authorName = authorNode
    ? authorNode.firstName && authorNode.lastName
        ? `${authorNode.firstName} ${authorNode.lastName}`
        : authorNode.name
    : "Editorial Team"

let authorAvatar =
    authorNode?.avatar?.url ||
    `https://ui-avatars.com/api/?name=${encodeURIComponent(authorName)}&background=f1f5f9&color=1e293b&bold=true`
authorAvatar = authorAvatar.replace(
    /https?:\/\/(www\.)?casinous\.com/gi,
    wpDomain,
)

const authorSlug = authorName
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)+/g, "")
const authorLink = `/about-us/${authorSlug}/`

const formatSocial = (value: string | undefined, domain: string) => {
    if (!value) return null
    return value.startsWith("http")
        ? value
        : `${domain}${value.replace(/^@/, "")}`
}

const authorSocials = authorNode?.seo?.social || {}
const twitterLink = formatSocial(authorSocials.twitter, "https://twitter.com/")
const facebookLink = formatSocial(
    authorSocials.facebook,
    "https://facebook.com/",
)
const instagramLink = formatSocial(
    authorSocials.instagram,
    "https://instagram.com/",
)
const linkedinLink = formatSocial(
    authorSocials.linkedIn,
    "https://linkedin.com/in/",
)

let reviewerName = "Paul Jacobs"
if (authorName.toLowerCase().includes("sarah")) {
    reviewerName = "David Reynolds"
}

const reviewerAvatars: Record<string, string> = {
    "Paul Jacobs":
        "https://secure.gravatar.com/avatar/5c4ed09c966f392059e806c5812445eda41c0f95e81217db92bc0865be4f1185?s=32&d=mm&r=g",
    "David Reynolds":
        "https://secure.gravatar.com/avatar/907015fdee956f1b4291ed4c4290571d3b2652adbe40b1938629a7d9b65a8f08?s=32&d=mm&r=g",
    "Paige Jacobs":
        "https://secure.gravatar.com/avatar/b5b0117907d6dc14bd89e93752ab00d26bb4608b5f3d0f4bff4d5545071120d3?s=32&d=mm&r=g",
}
const reviewerAvatar =
    reviewerAvatars[reviewerName] ||
    `https://ui-avatars.com/api/?name=${encodeURIComponent(reviewerName)}&background=f1f5f9&color=1e293b&bold=true`

const reviewerSlug = reviewerName
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/(^-|-$)+/g, "")
const reviewerLink = `/about-us/${reviewerSlug}/`

const rawDate = post.modified || post.date || new Date().toISOString()
const formattedDate = new Date(rawDate).toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
})

let featuredImageUrl = post.featuredImage?.node?.sourceUrl
if (featuredImageUrl) {
    try {
        const parsedUrl = new URL(featuredImageUrl)
        // 🚨 FIX: Extract relative path for the proxy
        featuredImageUrl = parsedUrl.pathname 
    } catch (e) {}
}

// --- 6. AUTO TABLE OF CONTENTS (TOC) GENERATOR ---
let rawContent = post.content || ""

if (post.uri.startsWith("/casino-reviews/")) {
    rawContent = rawContent.replace(/<h1[^>]*>[\s\S]*?<\/h1>/gi, "")
}

const tocItems: { text: string; slug: string }[] = []
const h2Regex = /<h2([^>]*)>([\s\S]*?)<\/h2>/gi
const contentWithIds = rawContent.replace(
    h2Regex,
    (match, attributes, text) => {
        const cleanText = text.replace(/<\/?[^>]+(>|$)/g, "").trim()
        const h2Slug = cleanText
            .toLowerCase()
            .replace(/[^a-z0-9]+/g, "-")
            .replace(/(^-|-$)+/g, "")
        if (cleanText.length > 0)
            tocItems.push({ text: cleanText, slug: h2Slug })
        if (attributes.includes("id=")) return match
        return `<h2${attributes} id="${h2Slug}">${text}</h2>`
    },
)

let tocHTML = ""
if (tocItems.length > 0) {
    const listItems = tocItems
        .map(
            item =>
                `<li><a href="#${item.slug}" class="toc-jump-link">${item.text}</a></li>`,
        )
        .join("")
    tocHTML = `
    <div class="custom-toc">
        <button class="toc-toggle" onclick="window.toggleTableOfContents(this)">
            <span>Table of Contents</span>
            <svg class="toc-icon" viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="2" fill="none"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <ul class="toc-list" style="display: none;">${listItems}</ul>
    </div>`
}

const displayTitle = (post.title || "").replaceAll("[year]", currentYear)

// --- 7. FINAL CONTENT REPLACEMENTS ---
const fixedContent = contentWithIds
    .replaceAll("[casino_toc]", tocHTML)
    .replace(/src="[^"]*placeholder[^"]*"/gi, "")
    .replaceAll('data-src="/wp-content/', 'src="/wp-content/')
    .replaceAll('data-srcset="/wp-content/', 'srcset="/wp-content/')
    
    // 🚨 BULLETPROOF FIX: Globally strip the Cloudways domain from the entire HTML string.
    // This catches hrefs, src, and all the comma-separated links hiding inside srcset.
    .replaceAll(wpDomain, "") 
    
    .replaceAll("<img ", '<img referrerpolicy="no-referrer" ')
    .replaceAll("<p>&nbsp;</p>", "")
    .replaceAll("<p>[author_reviewer]</p>", "")
    .replace(
        /<p>\s*<(strong|b)>\s*Accepts players from:\s*<\/(strong|b)>.*?<\/p>/gi,
        "",
    )
    .replace(
        /<p[^>]*>\s*<(strong|b)[^>]*>\s*Last Update:\s*<\/(strong|b)>[\s\S]*?<\/p>/gi,
        "",
    )
    .replace(
        /<p>\s*<(strong|b)>.*?Reviews and Ratings\s*<\/(strong|b)>\s*<\/p>/gi,
        "",
    )
    .replace(/<p>\s*\[casino_toc\]\s*<\/p>/gi, "")
    .replaceAll("[casino_toc]", "") // Failsafe in case it's not in a <p> tag
    .replace(/<p>\s*<(strong|b)>\s*Updated:\s*<\/(strong|b)>.*?<\/p>/gi, "")
    .replace(/<h1[^>]*>[\s\S]*?<\/h1>/i, "")
    .replaceAll("[year]", currentYear)
---

<Layout
    title={`${post.title} | AU Casinos Online`}
    seoTitle={yoastTitle}
    description={yoastDesc}
    schema={yoastSchema}
    canonical={canonicalUrl}
    robots={robotsTag}
    keywords={focusKeyword}
    author={authorName}
>
    <header class={isPost ? "post-hero" : "page-hero"}>
        <div class={isPost ? "post-hero-container" : "page-hero-container"}>
            <nav class="post-breadcrumbs" aria-label="breadcrumb">
                {
                    yoastBreadcrumbs.length > 0 ? (
                        yoastBreadcrumbs.map((crumb: any) =>
                            crumb.isLast ? (
                                <span class="current" set:html={crumb.text} />
                            ) : (
                                <>
                                    <a href={crumb.url} set:html={crumb.text} />
                                    <span class="separator">›</span>
                                </>
                            ),
                        )
                    ) : (
                        /* Fallback if Yoast breadcrumbs are missing */
                        <>
                            <a href="/">Home</a>
                            <span class="separator">›</span>
                            <span
                                class="current"
                                set:html={
                                    focusKeyword
                                        ? focusKeyword.charAt(0).toUpperCase() +
                                          focusKeyword.slice(1)
                                        : displayTitle
                                }
                            />
                        </>
                    )
                }
            </nav>

            <h1
                class={isPost ? "post-title" : "page-title"}
                set:html={displayTitle}
            />

            <div class="post-meta-bar">
                <div class="meta-author">
                    <a
                        href={authorLink}
                        class="author-image-link"
                        aria-label={`View ${authorName}'s profile`}
                    >
                        <img
                            src={authorAvatar}
                            alt={authorName}
                            class="meta-avatar"
                            referrerpolicy="no-referrer"
                        />
                    </a>
                    <div>
                        <span class="meta-name"
                            >By <a href={authorLink} class="author-text-link"
                                ><strong>{authorName}</strong></a
                            ></span
                        >
                        <span class="meta-date">Updated: {formattedDate}</span>
                    </div>
                </div>

                <div class="meta-share">
                    {
                        twitterLink && (
                            <a
                                href={twitterLink}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="share-btn twitter"
                                aria-label="Twitter"
                            >
                                <i class="fa-brands fa-twitter" />
                            </a>
                        )
                    }
                    {
                        facebookLink && (
                            <a
                                href={facebookLink}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="share-btn facebook"
                                aria-label="Facebook"
                            >
                                <i class="fa-brands fa-facebook-f" />
                            </a>
                        )
                    }
                    {
                        instagramLink && (
                            <a
                                href={instagramLink}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="share-btn instagram"
                                aria-label="Instagram"
                            >
                                <i class="fa-brands fa-instagram" />
                            </a>
                        )
                    }
                    {
                        linkedinLink && (
                            <a
                                href={linkedinLink}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="share-btn linkedin"
                                aria-label="LinkedIn"
                            >
                                <i class="fa-brands fa-linkedin-in" />
                            </a>
                        )
                    }
                </div>
            </div>
        </div>
    </header>
    <main class={isPost ? "post-wrapper" : "page-wrapper"}>
        <article
            class={isPost
                ? "post-container"
                : "page-container cus-page-container"}
        >
            {
                isPost && featuredImageUrl && (
                    <div class="featured-image-wrapper">
                        <img
                            src={featuredImageUrl}
                            alt={post.title}
                            class="featured-image"
                            referrerpolicy="no-referrer"
                        />
                    </div>
                )
            }

            {
                isPost && (
                    <div
                        class="cus-author-profiles"
                        style="margin-bottom: 2rem; display: flex; gap: 1.5rem; align-items: center; justify-content: flex-start; padding: 1rem; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0;"
                    >
                        <div
                            class="cus-author-item"
                            style="display: flex; gap: 1rem; align-items: center;"
                        >
                            <a
                                href={reviewerLink}
                                aria-label={`View ${reviewerName}'s profile`}
                            >
                                <Image
                                    src={reviewerAvatar}
                                    alt={`Reviewer ${reviewerName}`}
                                    width={50}
                                    height={50}
                                    class="meta-avatar"
                                />
                            </a>
                            <div>
                                <span style="display: block; font-size: 0.9rem; color: #475569;">
                                    Reviewed By{" "}
                                    <a
                                        href={reviewerLink}
                                        style="color: #0f172a; text-decoration: none;"
                                    >
                                        <strong>{reviewerName}</strong>
                                    </a>
                                </span>
                                <span style="display: block; font-size: 0.8rem; color: #64748b;">
                                    Casino Expert
                                </span>
                            </div>
                        </div>
                    </div>
                )
            }

            <div class="wp-content" set:html={fixedContent} />
        </article>
    </main>

    {/* RELATED POSTS - Moved OUTSIDE the main tag to allow full width */}
    {
        isPost && relatedPosts.length > 0 && (
            <section class="full-width-discovery-section">
                <div class="discovery-container">
                    <div class="discovery-columns">
                        <div class="discovery-left-col">
                            <h2 class="discovery-section-title">
                                Read today's breaking stories
                            </h2>
                            <div class="breaking-stories-list">
                                {breakingStories.map((story: any) => {
                                    let relativeUri = story.uri
                                        ? story.uri.replace(
                                              /https?:\/\/[^\/]+/g,
                                              "",
                                          )
                                        : "/"
                                    const cleanSlug = relativeUri.replace(
                                        /^\/|\/$/g,
                                        "",
                                    )
                                    const storyLink = `/${cleanSlug}/`
                                    const storyDate = new Date(
                                        story.date,
                                    ).toLocaleDateString("en-US", {
                                        year: "numeric",
                                        month: "short",
                                        day: "numeric",
                                    })

                                    let storyImage =
                                        story.featuredImage?.node?.sourceUrl ||
                                        "https://via.placeholder.com/300x150"
                                    try {
                                        const parsedUrl = new URL(storyImage)
                                        // 🚨 FIX: Extract relative path for proxying
                                        storyImage = parsedUrl.pathname
                                    } catch (e) {}

                                    const authorObj = story.author?.node
                                    const recAuthorName = authorObj
                                        ? authorObj.firstName &&
                                          authorObj.lastName
                                            ? `${authorObj.firstName} ${authorObj.lastName}`
                                            : authorObj.name
                                        : "Editorial Team"
                                    let recAuthorAvatar =
                                        authorObj?.avatar?.url ||
                                        `https://ui-avatars.com/api/?name=${encodeURIComponent(recAuthorName)}&background=f1f5f9&color=1e293b&bold=true`

                                    return (
                                        <div class="breaking-story-card">
                                            <div class="breaking-story-image">
                                                <a
                                                    href={storyLink}
                                                    class="thumbnail-link"
                                                >
                                                    <img
                                                        src={storyImage}
                                                        alt={
                                                            story.featuredImage
                                                                ?.node
                                                                ?.altText ||
                                                            story.title
                                                        }
                                                        loading="lazy"
                                                        referrerpolicy="no-referrer"
                                                    />
                                                </a>
                                            </div>
                                            <div class="breaking-story-content">
                                                <div class="card-meta-top">
                                                    <span class="card-category">
                                                        News
                                                    </span>
                                                    <span class="card-date">
                                                        {storyDate}
                                                    </span>
                                                </div>
                                                <a
                                                    href={storyLink}
                                                    class="card-title-link"
                                                >
                                                    <h3
                                                        set:html={story.title}
                                                    />
                                                </a>
                                                <div class="card-meta-bottom">
                                                    <img
                                                        src={recAuthorAvatar}
                                                        alt={recAuthorName}
                                                        class="card-author-avatar"
                                                    />
                                                    <span>
                                                        {recAuthorName} • 10 min
                                                        read
                                                    </span>
                                                </div>
                                            </div>
                                        </div>
                                    )
                                })}
                            </div>
                        </div>

                        <div class="discovery-right-col">
                            <h2 class="discovery-section-title">
                                Discover our blogs
                            </h2>
                            <div class="discover-blogs-list">
                                {blogPosts.map((blogPost: any) => {
                                    let relativeUri = blogPost.uri
                                        ? blogPost.uri.replace(
                                              /https?:\/\/[^\/]+/g,
                                              "",
                                          )
                                        : "/"
                                    const cleanSlug = relativeUri.replace(
                                        /^\/|\/$/g,
                                        "",
                                    )
                                    const blogLink = `/${cleanSlug}/`
                                    const blogDate = new Date(
                                        blogPost.date,
                                    ).toLocaleDateString("en-US", {
                                        year: "numeric",
                                        month: "short",
                                        day: "numeric",
                                    })

                                    let blogImage =
                                        blogPost.featuredImage?.node
                                            ?.sourceUrl ||
                                        "https://via.placeholder.com/150"
                                    try {
                                        const parsedUrl = new URL(blogImage)
                                        // 🚨 FIX: Extract relative path for proxying
                                        blogImage = parsedUrl.pathname
                                    } catch (e) {}

                                    const authorObj = blogPost.author?.node
                                    const blogAuthorName = authorObj
                                        ? authorObj.firstName &&
                                          authorObj.lastName
                                            ? `${authorObj.firstName} ${authorObj.lastName}`
                                            : authorObj.name
                                        : "Editorial Team"
                                    let blogAuthorAvatar =
                                        authorObj?.avatar?.url ||
                                        `https://ui-avatars.com/api/?name=${encodeURIComponent(blogAuthorName)}&background=f1f5f9&color=1e293b&bold=true`

                                    return (
                                        <div class="blog-post-card">
                                            <div class="blog-post-image">
                                                <a href={blogLink}>
                                                    <img
                                                        src={blogImage}
                                                        alt={
                                                            blogPost
                                                                .featuredImage
                                                                ?.node
                                                                ?.altText ||
                                                            blogPost.title
                                                        }
                                                        loading="lazy"
                                                        referrerpolicy="no-referrer"
                                                    />
                                                </a>
                                            </div>
                                            <div class="blog-post-content">
                                                <a
                                                    href={blogLink}
                                                    class="blog-title-link"
                                                >
                                                    <h3
                                                        set:html={
                                                            blogPost.title
                                                        }
                                                    />
                                                </a>
                                                <div class="blog-meta">
                                                    <div class="blog-meta-author">
                                                        <img
                                                            src={
                                                                blogAuthorAvatar
                                                            }
                                                            alt={blogAuthorName}
                                                            class="blog-author-avatar"
                                                        />
                                                        <span>
                                                            {blogAuthorName} •{" "}
                                                            {blogDate}
                                                        </span>
                                                    </div>
                                                    <a
                                                        href={blogLink}
                                                        class="blog-read-more"
                                                    >
                                                        Read{" "}
                                                        <i class="fa-solid fa-arrow-right" />
                                                    </a>
                                                </div>
                                            </div>
                                        </div>
                                    )
                                })}
                            </div>
                        </div>
                    </div>
                </div>
            </section>
        )
    }
</Layout>

<script is:inline>
    window.toggleTableOfContents = function (btn) {
        const list = btn.nextElementSibling
        const icon = btn.querySelector(".toc-icon")

        if (list.style.display === "none") {
            list.style.display = "block"
            icon.style.transform = "rotate(180deg)"
        } else {
            list.style.display = "none"
            icon.style.transform = "rotate(0deg)"
        }
    }

    document.addEventListener("click", function (e) {
        const link = e.target.closest(".toc-jump-link")
        if (!link) return

        e.preventDefault()

        const targetId = link.getAttribute("href").substring(1)
        const targetElement = document.getElementById(targetId)

        if (targetElement) {
            targetElement.scrollIntoView({ behavior: "smooth", block: "start" })
            history.pushState(null, null, `#${targetId}`)
        }
    })

    // Toggle Content Functions
    window.toggleContent = function (btn) {
        const content = btn.parentElement.nextElementSibling
        if (content.style.display === "block") {
            content.style.display = "none"
            btn.innerText = "Show more"
        } else {
            content.style.display = "block"
            btn.innerText = "Show less"
        }
    }
</script>

